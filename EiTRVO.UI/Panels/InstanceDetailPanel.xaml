<UserControl x:Class="EiTRVO.UI.Panels.InstanceDetailPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

            <Grid >
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Header: back button + instance name -->
                <Border Grid.Row="0" Padding="24,16,24,10"
                        BorderBrush="{DynamicResource SidebarBorder}"
                        BorderThickness="0,0,0,1">
                    <Grid>
                        <StackPanel Orientation="Horizontal">
                            <Button Content="← 返回"
                                    Style="{StaticResource CardBtn}"
                                    Foreground="{DynamicResource AccentBlue}"
                                    Height="28" FontSize="12" Padding="10,3"
                                    Command="{Binding GoBackCommand}"/>
                            <TextBlock Text="{Binding InstanceName}"
                                       FontSize="20" FontWeight="Bold"
                                       Foreground="{DynamicResource TextPrimary}"
                                       VerticalAlignment="Center"
                                       Margin="16,0,0,0"/>
                            <!-- Mod Loader badge in header -->
                            <Border Background="{DynamicResource AccentBlue}"
                                    CornerRadius="4" Padding="8,2"
                                    Margin="10,0,0,0"
                                    VerticalAlignment="Center">
                                <TextBlock Text="{Binding LoaderType}"
                                           FontSize="11" Foreground="White"
                                           FontWeight="SemiBold"/>
                            </Border>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Body: info + placeholder sections -->
                <ScrollViewer Grid.Row="1"
                              VerticalScrollBarVisibility="Auto"
                              Padding="24,12,24,16">
                    <StackPanel>
                        <!-- 基本信息 -->
                        <GroupBox Header="基本信息" Padding="12" Margin="0,4">
                            <StackPanel>
                                <Grid Margin="0,2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="实例名称"
                                               Foreground="{DynamicResource TextSecondary}"
                                               FontSize="12" Margin="0,0,12,0"/>
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding InstanceName}"
                                               Foreground="{DynamicResource TextPrimary}"
                                               FontSize="12"/>
                                </Grid>
                                <Grid Margin="0,2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="游戏版本"
                                               Foreground="{DynamicResource TextSecondary}"
                                               FontSize="12" Margin="0,0,12,0"/>
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding VersionId}"
                                               Foreground="{DynamicResource TextPrimary}"
                                               FontSize="12"/>
                                </Grid>
                                <Grid Margin="0,2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Mod 加载器"
                                               Foreground="{DynamicResource TextSecondary}"
                                               FontSize="12" Margin="0,0,12,0"/>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                                        <TextBlock Text="{Binding LoaderType}"
                                                   Foreground="{DynamicResource AccentBlue}"
                                                   FontSize="12" FontWeight="SemiBold"/>
                                        <TextBlock Margin="6,0,0,0"
                                                   Foreground="{DynamicResource TextMuted}"
                                                   FontSize="11">
                                            <Run Text="{Binding LoaderVersion, Mode=OneWay}"
                                                 Foreground="{DynamicResource TextMuted}"/>
                                        </TextBlock>
                                    </StackPanel>
                                </Grid>
                                <Grid Margin="0,2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="实例路径"
                                               Foreground="{DynamicResource TextSecondary}"
                                               FontSize="12" Margin="0,0,12,0"/>
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding InstancePath}"
                                               Foreground="{DynamicResource TextPrimary}"
                                               FontSize="12"
                                               TextTrimming="CharacterEllipsis"/>
                                </Grid>
                                <Grid Margin="0,2"
                                      Visibility="{Binding UseIsolatedDir, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="隔离目录"
                                               Foreground="{DynamicResource TextSecondary}"
                                               FontSize="12" Margin="0,0,12,0"/>
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding IsolatedDir}"
                                               Foreground="{DynamicResource AccentGreen}"
                                               FontSize="12"
                                               TextTrimming="CharacterEllipsis"/>
                                </Grid>
                                <!-- 游戏时长统计 -->
                                <Grid Margin="0,2"
                                      Visibility="{Binding ShowPlayTime, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="累计时长"
                                               Foreground="{DynamicResource TextSecondary}"
                                               FontSize="12" Margin="0,0,12,0"/>
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding PlayTimeDisplay}"
                                               Foreground="{DynamicResource TextPrimary}"
                                               FontSize="12"/>
                                </Grid>
                                <Grid Margin="0,2"
                                      Visibility="{Binding ShowPlayTime, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="最后游玩"
                                               Foreground="{DynamicResource TextSecondary}"
                                               FontSize="12" Margin="0,0,12,0"/>
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding LastPlayedDisplay}"
                                               Foreground="{DynamicResource TextPrimary}"
                                               FontSize="12"/>
                                </Grid>
                            </StackPanel>
                        </GroupBox>

                        <!-- Mod 管理 + 导入存档 -->
                        <StackPanel Orientation="Horizontal" Margin="0,4">
                            <Button Content="Mod 管理"
                                    Style="{StaticResource PrimaryBtn}"
                                    Height="34" FontSize="13" FontWeight="Bold"
                                    Padding="20,4" Margin="0,0,8,0"
                                    Visibility="{Binding ShowModManagement, Converter={StaticResource BoolToVisibilityConverter}}"
                                    Command="{Binding OpenModManagementCommand}"/>
                            <Button Content="导入存档"
                                    Style="{StaticResource PrimaryBtn}"
                                    Height="34" FontSize="13" FontWeight="Bold"
                                    Padding="20,4"
                                    Command="{Binding ImportSaveCommand}"/>
                            <Button Content="资源 &amp; 光影"
                                    Style="{StaticResource PrimaryBtn}"
                                    Height="34" FontSize="13" FontWeight="Bold"
                                    Padding="20,4" Margin="8,0,0,0"
                                    Command="{Binding OpenResourcePacksCommand}"/>
                            <Button Content="投影管理"
                                    Style="{StaticResource PrimaryBtn}"
                                    Height="34" FontSize="13" FontWeight="Bold"
                                    Padding="20,4" Margin="8,0,0,0"
                                    Visibility="{Binding ShowSchematicManagement, Converter={StaticResource BoolToVisibilityConverter}}"
                                    Command="{Binding OpenSchematicManagementCommand}"/>
                        </StackPanel>

                        <!-- 存档锁 -->
                        <GroupBox Header="存档锁" Padding="12" Margin="0,4">
                            <StackPanel>
                                <!-- 空状态 -->
                                <TextBlock Text="暂无存档。在游戏中创建世界后会自动显示。"
                                           FontSize="12"
                                           Foreground="{DynamicResource TextMuted}"
                                           Margin="0,0,0,8"
                                           Visibility="{Binding HasSaveLockEntries, Converter={StaticResource BoolInvertConverter}}"/>

                                <!-- 存档数量 -->
                                <TextBlock FontSize="11" Margin="0,0,0,6"
                                           Foreground="{DynamicResource TextSecondary}"
                                           Visibility="{Binding HasSaveLockEntries, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <Run Text="共 "/>
                                    <Run Text="{Binding SaveLockCount}" FontWeight="SemiBold"/>
                                    <Run Text=" 个存档 (加密/未加密)"/>
                                </TextBlock>

                                <!-- 存档锁列表 -->
                                <ListBox x:Name="lstSaveLocks"
                                         SelectionMode="Single"
                                         ItemsSource="{Binding SaveLockEntries}"
                                         ItemTemplate="{StaticResource SaveLockCardTemplate}"
                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                         Visibility="{Binding HasSaveLockEntries, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <ListBox.ItemContainerStyle>
                                        <Style TargetType="ListBoxItem">
                                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                            <Setter Property="Padding" Value="0"/>
                                        </Style>
                                    </ListBox.ItemContainerStyle>
                                </ListBox>
                            </StackPanel>
                        </GroupBox>

                        <!-- 存档 -->
                        <GroupBox Header="存档" Padding="12" Margin="0,4">
                            <StackPanel>
                                <!-- 空状态 -->
                                <TextBlock Text="暂无存档。在游戏中创建世界后会自动显示。"
                                           FontSize="12"
                                           Foreground="{DynamicResource TextMuted}"
                                           Margin="0,0,0,8"
                                           Visibility="{Binding HasSaves, Converter={StaticResource BoolInvertConverter}}"/>

                                <!-- 存档数量 -->
                                <TextBlock FontSize="11" Margin="0,0,0,6"
                                           Foreground="{DynamicResource TextSecondary}"
                                           Visibility="{Binding HasSaves, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <Run Text="共 "/>
                                    <Run Text="{Binding SaveCount}" FontWeight="SemiBold"/>
                                    <Run Text=" 个存档"/>
                                </TextBlock>

                                <!-- 存档列表 -->
                                <ListBox x:Name="lstSaves"
                                         SelectionMode="Single"
                                         ItemsSource="{Binding SaveEntries}"
                                         ItemTemplate="{StaticResource SaveCardTemplate}"
                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                         Visibility="{Binding HasSaves, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <ListBox.ItemContainerStyle>
                                        <Style TargetType="ListBoxItem">
                                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                            <Setter Property="Padding" Value="0"/>
                                        </Style>
                                    </ListBox.ItemContainerStyle>
                                </ListBox>
                            </StackPanel>
                        </GroupBox>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
</UserControl>