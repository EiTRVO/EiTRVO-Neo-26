<UserControl x:Class="EiTRVO.UI.Panels.SaveLockDetailPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header: back button + save name -->
        <Border Grid.Row="0" Padding="24,16,24,10"
                BorderBrush="{DynamicResource SidebarBorder}"
                BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal">
                <Button Content="← 返回"
                        Style="{StaticResource CardBtn}"
                        Foreground="{DynamicResource AccentBlue}"
                        Height="28" FontSize="12" Padding="10,3"
                        Command="{Binding GoBackCommand}"/>
                <TextBlock Text="{Binding SaveName}"
                           FontSize="20" FontWeight="Bold"
                           Foreground="{DynamicResource TextPrimary}"
                           VerticalAlignment="Center"
                           Margin="16,0,0,0"/>
            </StackPanel>
        </Border>

        <!-- Body -->
        <ScrollViewer Grid.Row="1" Padding="24,12,24,16"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <!-- 存档信息 -->
                <GroupBox Header="存档信息" Padding="12" Margin="0,4">
                    <StackPanel>
                        <Grid Margin="0,2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="存档名称"
                                       Foreground="{DynamicResource TextSecondary}"
                                       FontSize="12" Margin="0,0,12,0"/>
                            <TextBlock Grid.Column="1"
                                       Text="{Binding SaveName}"
                                       Foreground="{DynamicResource TextPrimary}"
                                       FontSize="12"/>
                        </Grid>
                        <Grid Margin="0,2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="所属实例"
                                       Foreground="{DynamicResource TextSecondary}"
                                       FontSize="12" Margin="0,0,12,0"/>
                            <TextBlock Grid.Column="1"
                                       Text="{Binding InstanceName}"
                                       Foreground="{DynamicResource TextPrimary}"
                                       FontSize="12"/>
                        </Grid>
                        <Grid Margin="0,2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="锁定状态"
                                       Foreground="{DynamicResource TextSecondary}"
                                       FontSize="12" Margin="0,0,12,0"/>
                            <TextBlock Grid.Column="1" FontSize="12">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="未锁定"/>
                                        <Setter Property="Foreground" Value="{DynamicResource AccentGreen}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsLocked}" Value="True">
                                                <Setter Property="Text" Value="已锁定"/>
                                                <Setter Property="Foreground" Value="{DynamicResource AccentBlue}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                        <!-- 加密模式 (仅已锁定时显示) -->
                        <Grid Margin="0,2"
                              Visibility="{Binding IsLocked, Converter={StaticResource BoolToVisibilityConverter}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="加密模式"
                                       Foreground="{DynamicResource TextSecondary}"
                                       FontSize="12" Margin="0,0,12,0"/>
                            <TextBlock Grid.Column="1"
                                       Text="{Binding LockModeDisplay}"
                                       Foreground="{DynamicResource TextPrimary}"
                                       FontSize="12"/>
                        </Grid>
                        <!-- 锁定时间 (仅已锁定时显示) -->
                        <Grid Margin="0,2"
                              Visibility="{Binding IsLocked, Converter={StaticResource BoolToVisibilityConverter}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="锁定时间"
                                       Foreground="{DynamicResource TextSecondary}"
                                       FontSize="12" Margin="0,0,12,0"/>
                            <TextBlock Grid.Column="1"
                                       Text="{Binding LockedAtDisplay}"
                                       Foreground="{DynamicResource TextPrimary}"
                                       FontSize="12"/>
                        </Grid>
                        <!-- 绑定账户 (仅有绑定时显示) -->
                        <Grid Margin="0,2"
                              Visibility="{Binding HasBoundAccount, Converter={StaticResource BoolToVisibilityConverter}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="绑定账户"
                                       Foreground="{DynamicResource TextSecondary}"
                                       FontSize="12" Margin="0,0,12,0"/>
                            <TextBlock Grid.Column="1"
                                       Text="{Binding BoundMsAccount}"
                                       Foreground="{DynamicResource TextPrimary}"
                                       FontSize="12"/>
                        </Grid>
                        <!-- 密码提示 (仅已锁定时显示) -->
                        <Grid Margin="0,2"
                              Visibility="{Binding IsLocked, Converter={StaticResource BoolToVisibilityConverter}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="密码提示"
                                       Foreground="{DynamicResource TextSecondary}"
                                       FontSize="12" Margin="0,0,12,0"/>
                            <TextBlock Grid.Column="1"
                                       Text="{Binding PasswordHint}"
                                       Foreground="{DynamicResource TextPrimary}"
                                       FontSize="12"/>
                        </Grid>
                        <!-- OneDrive 备份状态 (仅已锁定时显示) -->
                        <Grid Margin="0,2"
                              Visibility="{Binding IsLocked, Converter={StaticResource BoolToVisibilityConverter}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="OneDrive 备份"
                                       Foreground="{DynamicResource TextSecondary}"
                                       FontSize="12" Margin="0,0,12,0"/>
                            <TextBlock Grid.Column="1" FontSize="12">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="未备份"/>
                                        <Setter Property="Foreground" Value="{DynamicResource AccentRed}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding OneDriveBackedUp}" Value="True">
                                                <Setter Property="Text" Value="已备份"/>
                                                <Setter Property="Foreground" Value="{DynamicResource AccentGreen}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </StackPanel>
                </GroupBox>

                <!-- 概览信息 -->
                <TextBlock Text="{Binding InfoDisplay}"
                           FontSize="12"
                           Foreground="{DynamicResource TextMuted}"
                           Margin="4,6,0,0"/>

                <!-- 未加密状态 —— 锁定此存档 -->
                <StackPanel Margin="0,12"
                            Visibility="{Binding IsLocked, Converter={StaticResource BoolInvertConverter}}">
                    <TextBlock Text="此存档当前未加密。"
                               FontSize="13"
                               Foreground="{DynamicResource TextSecondary}"
                               Margin="0,0,0,8"/>
                    <Button Content="锁定此存档"
                            Style="{StaticResource PrimaryBtn}"
                            Height="34" FontSize="13" FontWeight="Bold"
                            Padding="20,4"
                            Command="{Binding LockSaveCommand}"/>
                </StackPanel>

                <!-- 已加密状态 —— 管理操作 -->
                <StackPanel Margin="0,12"
                            Visibility="{Binding IsLocked, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Button Content="解密存档"
                            Style="{StaticResource PrimaryBtn}"
                            Height="34" FontSize="13" FontWeight="Bold"
                            Padding="20,4" Margin="0,0,0,8"
                            Command="{Binding DecryptSaveCommand}"/>
                    <Button Content="导出密钥备份 (.savkey)"
                            Style="{StaticResource CardBtn}"
                            Height="34" FontSize="13" FontWeight="Bold"
                            Padding="20,4" Margin="0,0,0,8"
                            Visibility="{Binding ShowRetryOneDrive, Converter={StaticResource BoolToVisibilityConverter}}"
                            Command="{Binding RetryOneDriveBackupCommand}"/>
                    <Button Content="导出恢复文件 (.savrec)"
                            Style="{StaticResource CardBtn}"
                            Height="34" FontSize="13" FontWeight="Bold"
                            Padding="20,4"
                            Visibility="{Binding HasMsAccount, Converter={StaticResource BoolToVisibilityConverter}}"
                            Command="{Binding ExportRecoveryFileCommand}"/>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
