<Window x:Class="EiTRVO.UI.Panels.UnlockPanel"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="存档已锁定" MinHeight="300" Height="380" Width="460"
        FontFamily="{StaticResource CustomFont}"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False"
        ResizeMode="NoResize"
        Background="{DynamicResource WindowBg}">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Grid.Row="0" Text="存档已锁定"
                   FontSize="16" FontWeight="Bold"
                   Foreground="{DynamicResource TextPrimary}"
                   Margin="0,0,0,12"/>

        <!-- Save metadata + password -->
        <StackPanel Grid.Row="1">
            <!-- Metadata - single save -->
            <StackPanel x:Name="pnlSingleSave">
                <Grid Margin="0,2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="存档:"
                               Foreground="{DynamicResource TextSecondary}" FontSize="12"/>
                    <TextBlock x:Name="lblSaveName" Grid.Column="1"
                               Foreground="{DynamicResource TextPrimary}" FontSize="12"
                               FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                </Grid>
                <Grid Margin="0,2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="实例:"
                               Foreground="{DynamicResource TextSecondary}" FontSize="12"/>
                    <TextBlock x:Name="lblInstanceName" Grid.Column="1"
                               Foreground="{DynamicResource TextPrimary}" FontSize="12"/>
                </Grid>
                <Grid Margin="0,2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="模式:"
                               Foreground="{DynamicResource TextSecondary}" FontSize="12"/>
                    <TextBlock x:Name="lblLockMode" Grid.Column="1"
                               Foreground="{DynamicResource TextPrimary}" FontSize="12"/>
                </Grid>
                <Grid Margin="0,2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="锁定时间:"
                               Foreground="{DynamicResource TextSecondary}" FontSize="12"/>
                    <TextBlock x:Name="lblLockedAt" Grid.Column="1"
                               Foreground="{DynamicResource TextPrimary}" FontSize="12"/>
                </Grid>
                <Grid Margin="0,2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="绑定账户:"
                               Foreground="{DynamicResource TextSecondary}" FontSize="12"/>
                    <TextBlock x:Name="lblBoundAccount" Grid.Column="1"
                               Foreground="{DynamicResource TextPrimary}" FontSize="12"/>
                </Grid>
            </StackPanel>

            <!-- Multi-save list (hidden for single save) -->
            <ListBox x:Name="lstMultipleSaves" Margin="0,0,0,8"
                     Visibility="Collapsed"
                     MaxHeight="120">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="Padding" Value="2,1"/>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal">
                            <CheckBox IsChecked="{Binding IsSelected}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <StackPanel>
                                <TextBlock Text="{Binding DisplayText}" FontSize="12"
                                           Foreground="{DynamicResource TextPrimary}" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding DetailText}" FontSize="10"
                                           Foreground="{DynamicResource TextMuted}"/>
                            </StackPanel>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!-- Password input -->
            <TextBlock Text="请输入密码解锁:"
                       Foreground="{DynamicResource TextSecondary}" FontSize="12"
                       Margin="0,8,0,4"/>
            <PasswordBox x:Name="txtPassword" Height="32" FontSize="13"
                         Background="{DynamicResource Surface}"
                         BorderBrush="{DynamicResource PanelBorder}"
                         Margin="0,0,0,4"/>

            <!-- Password hint -->
            <TextBlock x:Name="lblPasswordHint" FontSize="11"
                       Foreground="{DynamicResource TextMuted}"
                       Margin="0,0,0,6" TextWrapping="Wrap"
                       Visibility="Collapsed"/>

            <!-- Error -->
            <TextBlock x:Name="lblError" FontSize="12"
                       Foreground="{DynamicResource AccentRed}"
                       Visibility="Collapsed" Margin="0,0,0,4"
                       TextWrapping="Wrap"/>
        </StackPanel>

        <!-- Buttons -->
        <StackPanel Grid.Row="2" Margin="0,8,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Forgot password link (only if has MS account) -->
                <Button x:Name="btnForgotPassword" Grid.Column="0"
                        Content="忘记密码?"
                        Style="{StaticResource CardBtn}"
                        Foreground="{DynamicResource AccentBlue}"
                        Height="28" FontSize="12" Padding="8,3"
                        HorizontalAlignment="Left"
                        Click="BtnForgotPassword_Click"
                        Visibility="Collapsed"/>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="取消"
                            Style="{StaticResource CardBtn}"
                            Height="30" FontSize="12" Padding="14,3"
                            Margin="0,0,8,0" IsCancel="True"/>
                    <Button Content="解锁"
                            Style="{StaticResource PrimaryBtn}"
                            Height="30" FontSize="12" Padding="14,3"
                            Click="BtnUnlock_Click"/>
                </StackPanel>
            </Grid>
        </StackPanel>
    </Grid>
</Window>
