<UserControl x:Class="EiTRVO.UI.Panels.SettingsPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

            <Grid >
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              Padding="24,16,24,16">
                    <StackPanel>
                        <TextBlock Text="启动设置" FontSize="18"
                                   FontWeight="Bold" Margin="0,0,0,12"
                                   Foreground="{DynamicResource TextPrimary}"/>

                        <GroupBox Header="启动内存 (MB)" Padding="12"
                                  Margin="0,4">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Slider x:Name="sliderMemory" Minimum="256"
                                        Maximum="32768"
                                        TickFrequency="256"
                                        IsSnapToTickEnabled="True"
                                        Value="{Binding Memory, Mode=TwoWay}"/>
                                <StackPanel Grid.Column="1"
                                            Orientation="Horizontal"
                                            Margin="10,0,0,0">
                                    <TextBox x:Name="txtMemory" Width="60"
                                             Height="28"
                                             Text="{Binding MemoryText, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"/>
                                    <TextBlock Text=" MB"
                                               VerticalAlignment="Center"
                                               Margin="5,0,0,0"
                                               Foreground="{DynamicResource TextSecondary}"/>
                                </StackPanel>
                            </Grid>
                        </GroupBox>

                        <GroupBox Header="游戏分辨率" Padding="12"
                                  Margin="0,4">
                            <StackPanel>
                                <ComboBox x:Name="cmbResolution" Height="30"
                                          SelectedValue="{Binding SelectedResolution, Mode=TwoWay}"
                                          SelectedValuePath="Content">
                                    <ComboBoxItem Content="默认 (不指定)"/>
                                    <ComboBoxItem Content="854 x 480"/>
                                    <ComboBoxItem Content="1280 x 720"/>
                                    <ComboBoxItem Content="1920 x 1080"/>
                                    <ComboBoxItem Content="2560 x 1440"/>
                                    <ComboBoxItem Content="自定义"/>
                                </ComboBox>
                                <StackPanel x:Name="pnlCustomResolution"
                                            Orientation="Horizontal"
                                            Margin="0,6"
                                            Visibility="{Binding IsCustomResolution, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <TextBlock Text="宽度："
                                               VerticalAlignment="Center"
                                               Foreground="{DynamicResource TextSecondary}"/>
                                    <TextBox x:Name="txtWidth" Width="60"
                                             Margin="5"
                                             Text="{Binding CustomWidth, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                    <TextBlock Text="高度："
                                               VerticalAlignment="Center"
                                               Foreground="{DynamicResource TextSecondary}"/>
                                    <TextBox x:Name="txtHeight" Width="60"
                                             Margin="5"
                                             Text="{Binding CustomHeight, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                </StackPanel>
                            </StackPanel>
                        </GroupBox>

                        <GroupBox Header="实例隔离" Padding="12" Margin="0,4">
                            <StackPanel>
                                <CheckBox x:Name="chkIsolateByDefault"
                                          Content="创建新实例时默认启用游戏目录隔离"
                                          FontSize="12"
                                          Foreground="{DynamicResource TextPrimary}"
                                          IsChecked="{Binding IsolateNewInstancesByDefault, Mode=TwoWay}"/>
                                <TextBlock Text="启用后每个实例的存档、Mod、配置等数据独立存放于版本目录下。已有实例不受影响。"
                                           FontSize="10" Foreground="{DynamicResource TextMuted}"
                                           TextWrapping="Wrap" Margin="0,6,0,0"/>
                            </StackPanel>
                        </GroupBox>

                        <GroupBox Header="Java 运行环境" Padding="12"
                                  Margin="0,4">
                            <StackPanel>
                                <!-- 开关：自动检测 vs 手动指定 -->
                                <CheckBox x:Name="chkAutoDetectJava"
                                          Content="自动检测 Java 运行环境"
                                          FontSize="12"
                                          Foreground="{DynamicResource TextPrimary}"
                                          IsChecked="{Binding UseAutoDetectJava, Mode=TwoWay}"
                                          Margin="0,0,0,8"/>

                                <!-- ===== 自动检测模式 ===== -->
                                <Button x:Name="btnDetectJava"
                                        Content="检测 Java"
                                        Style="{StaticResource CardBtn}"
                                        Height="30" Padding="10,3"
                                        Foreground="{DynamicResource AccentBlue}"
                                        Margin="0,0,0,6"
                                        Command="{Binding DetectJavaCommand}"
                                        Visibility="{Binding UseAutoDetectJava, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                <ListBox x:Name="lstJava" Height="110"
                                         SelectionMode="Single"
                                         ItemsSource="{Binding JavaList}"
                                         SelectedItem="{Binding SelectedJava, Mode=TwoWay}"
                                         ItemTemplate="{StaticResource JavaItemTemplate}"
                                         Margin="0,2,0,0"
                                         Visibility="{Binding UseAutoDetectJava, Converter={StaticResource BoolToVisibilityConverter}}"/>

                                <!-- ===== 手动指定模式 ===== -->
                                <StackPanel Orientation="Horizontal" Margin="0,2,0,0"
                                            Visibility="{Binding IsManualJavaMode, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <TextBox x:Name="txtManualJavaPath"
                                             Width="360" Height="28"
                                             Text="{Binding ManualJavaPath, Mode=OneWay}"
                                             IsReadOnly="True"
                                             VerticalAlignment="Center"
                                             ToolTip="{Binding ManualJavaPath}"/>
                                    <Button x:Name="btnBrowseJava"
                                            Content="浏览"
                                            Style="{StaticResource CardBtn}"
                                            Height="28" Padding="10,3"
                                            Foreground="{DynamicResource AccentBlue}"
                                            Margin="8,0,0,0"
                                            Command="{Binding BrowseJavaCommand}"/>
                                </StackPanel>

                                <TextBlock Text="提示：Forge / NeoForge 的安装需要有效的 Java 运行环境。请确保 Java 8+ 已正确配置。"
                                           FontSize="10" Foreground="{DynamicResource TextMuted}"
                                           TextWrapping="Wrap" Margin="0,6,0,0"/>
                            </StackPanel>
                        </GroupBox>

                        <GroupBox Header="设置锁" Padding="12" Margin="0,4">
                            <StackPanel>
                                <CheckBox x:Name="chkSettingsLock"
                                          Content="启用设置锁"
                                          FontSize="12"
                                          Foreground="{DynamicResource TextPrimary}"
                                          IsChecked="{Binding SettingsLockEnabled, Mode=TwoWay}"
                                          IsEnabled="{Binding IsWindowsHelloAvailable}"/>
                                <TextBlock Text="{Binding SettingsLockHint}"
                                           FontSize="10"
                                           Foreground="{DynamicResource TextMuted}"
                                           TextWrapping="Wrap"
                                           Margin="0,6,0,0"/>
                            </StackPanel>
                        </GroupBox>

                        <GroupBox Header="EiTRVO Firewall" Padding="12" Margin="0,4">
                            <StackPanel>
                                <CheckBox x:Name="chkFirewall"
                                          Content="启用游戏进程防护"
                                          FontSize="12"
                                          Foreground="{DynamicResource TextPrimary}"
                                          IsChecked="{Binding FirewallEnabled, Mode=TwoWay}"/>
                                <!-- 防护模式选择（仅防火墙启用时可见） -->
                                <StackPanel Margin="16,8,0,0"
                                            Visibility="{Binding IsAdvancedDefenseAvailable, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <TextBlock FontSize="11" Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,6">
                                        <Run Text="防护模式"/>
                                    </TextBlock>
                                    <RadioButton x:Name="rbStandardDefense"
                                                 GroupName="DefenseMode"
                                                 Content="标准防御"
                                                 FontSize="12"
                                                 Foreground="{DynamicResource TextPrimary}"
                                                 IsChecked="{Binding AdvancedDefenseEnabled, Mode=TwoWay, Converter={StaticResource BoolInvertConverter}}"
                                                 Margin="0,2"/>
                                    <RadioButton x:Name="rbAdvancedDefense"
                                                 GroupName="DefenseMode"
                                                 Content="高级防御"
                                                 FontSize="12"
                                                 Foreground="{DynamicResource TextPrimary}"
                                                 IsChecked="{Binding AdvancedDefenseEnabled, Mode=TwoWay}"
                                                 Margin="0,2"/>
                                </StackPanel>
                                <TextBlock FontSize="10"
                                           Foreground="{DynamicResource TextMuted}"
                                           TextWrapping="Wrap" Margin="0,6,0,0">
                                    <Run Text="开启后："/>
                                    <LineBreak/>
                                    <Run Text="1. 移除游戏进程的关机特权（阻止 shutdown.exe / ExitWindowsEx）；"/>
                                    <LineBreak/>
                                    <Run Text="2. 限制子进程数量上限（50 个），防止进程炸弹；"/>
                                    <LineBreak/>
                                    <Run Text="3. 监控并阻止游戏进程调用系统高危程序（cmd.exe, powershell.exe 等 30 项）。"/>
                                    <LineBreak/>
                                    <Run Text="检测到危险调用时自动终止游戏进程并弹出警告。如游戏出现异常可关闭此功能。" Foreground="{DynamicResource TextSecondary}"/>
                                </TextBlock>
                                <TextBlock FontSize="10"
                                           Foreground="{DynamicResource TextSecondary}"
                                           TextWrapping="Wrap" Margin="0,4,0,0"
                                           Visibility="{Binding AdvancedDefenseEnabled, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <Run Text="─────────────────────────────"/>
                                    <LineBreak/>
                                    <Run Text="◆ 高级防御额外提供："/>
                                    <LineBreak/>
                                    <Run Text="4. 文件系统监控 — 检测并阻止游戏释放可疑可执行文件；"/>
                                    <LineBreak/>
                                    <Run Text="5. DLL 加载监控 — 记录非标准模块加载用于安全审计；"/>
                                    <LineBreak/>
                                    <Run Text="6. TCP 连接监控 — 记录非标准端口连接用于安全审计；"/>
                                    <LineBreak/>
                                    <Run Text="高级模式的 DLL/网络监控仅记录证据不自动处置，完整保留攻击链信息供安全软件分析。"/>
                                    <LineBreak/>
                                    <Run Text="─────────────────────────────"/>
                                </TextBlock>
                            </StackPanel>
                        </GroupBox>

                        <!-- ==================== 下载 ==================== -->
                        <GroupBox Header="下载" Padding="12" Margin="0,4">
                            <StackPanel>
                                <CheckBox x:Name="chkDisableChunkedDownload"
                                          Content="禁用多线程分块下载（若网络不稳定可开启）"
                                          FontSize="12"
                                          Foreground="{DynamicResource TextPrimary}"
                                          IsChecked="{Binding DisableChunkedDownload, Mode=TwoWay}"/>
                                <TextBlock Text="关闭时使用多线程分块下载加速大文件获取。若下载频繁失败或网络环境限制并发连接，可开启此选项切换为传统单线程下载。"
                                           FontSize="10" Foreground="{DynamicResource TextMuted}"
                                           TextWrapping="Wrap" Margin="0,6,0,0"/>
                            </StackPanel>
                        </GroupBox>

                        <!-- ==================== 备份 ==================== -->
                        <GroupBox Header="备份" Padding="12" Margin="0,4">
                            <StackPanel>
                                <!-- 自动备份开关 -->
                                <CheckBox x:Name="chkBackupEnabled"
                                          Content="启用自动备份（启动器启动时检查）"
                                          FontSize="12"
                                          Foreground="{DynamicResource TextPrimary}"
                                          IsChecked="{Binding BackupEnabled, Mode=TwoWay}"/>

                                <!-- 备份间隔 -->
                                <StackPanel Orientation="Horizontal" Margin="0,8,0,0"
                                            Visibility="{Binding BackupEnabled, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <TextBlock Text="备份间隔：" VerticalAlignment="Center"
                                               Foreground="{DynamicResource TextSecondary}" FontSize="12"/>
                                    <ComboBox ItemsSource="{Binding BackupIntervalOptions}"
                                              SelectedValue="{Binding BackupInterval}"
                                              SelectedValuePath="Value"
                                              DisplayMemberPath="Label"
                                              Width="120" Height="28" Margin="8,0,0,0"/>
                                </StackPanel>

                                <!-- 下次备份时间 -->
                                <TextBlock Text="{Binding NextBackupDisplay}"
                                           FontSize="12" Foreground="{DynamicResource AccentGreen}"
                                           Margin="0,6,0,0"
                                           Visibility="{Binding BackupEnabled, Converter={StaticResource BoolToVisibilityConverter}}"/>

                                <!-- 备份文件夹 -->
                                <StackPanel Orientation="Horizontal" Margin="0,8,0,0"
                                            Visibility="{Binding BackupEnabled, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <TextBox Text="{Binding BackupFolder, Mode=OneWay}" IsReadOnly="True"
                                             Width="360" Height="28" VerticalAlignment="Center"
                                             ToolTip="{Binding BackupFolder}"/>
                                    <Button Content="浏览" Style="{StaticResource CardBtn}"
                                            Height="28" Padding="10,3" Margin="8,0,0,0"
                                            Foreground="{DynamicResource AccentBlue}"
                                            Command="{Binding BrowseBackupFolderCommand}"/>
                                </StackPanel>

                                <!-- 排除可重下载文件 -->
                                <CheckBox Content="排除 assets 和 libraries（可从 Mojang 重新下载，排除可大幅减小备份体积）"
                                          IsChecked="{Binding ExcludeRedownloadable, Mode=TwoWay}"
                                          Visibility="{Binding BackupEnabled, Converter={StaticResource BoolToVisibilityConverter}}"
                                          FontSize="12" Foreground="{DynamicResource TextPrimary}" Margin="0,8,0,0"/>

                                <!-- 手动备份按钮 -->
                                <Button Content="立即备份" Style="{StaticResource PrimaryBtn}"
                                        Command="{Binding BackupNowCommand}"
                                        Height="34" FontSize="13" FontWeight="Bold"
                                        Padding="20,4" Margin="0,10,0,0"/>

                                <!-- 分隔线 + 恢复区域 -->
                                <Separator Margin="0,12,0,8"/>

                                <TextBlock Text="恢复备份" FontWeight="SemiBold" FontSize="13"
                                           Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,8"/>

                                <!-- 选择备份文件 -->
                                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                    <TextBox Text="{Binding RestoreFilePath, Mode=OneWay}" IsReadOnly="True"
                                             Width="300" Height="28" VerticalAlignment="Center"
                                             ToolTip="{Binding RestoreFilePath}"/>
                                    <Button Content="浏览" Style="{StaticResource CardBtn}"
                                            Height="28" Padding="10,3" Margin="8,0,0,0"
                                            Foreground="{DynamicResource AccentBlue}"
                                            Command="{Binding BrowseRestoreFileCommand}"/>
                                </StackPanel>

                                <!-- 恢复模式 + 执行按钮 -->
                                <StackPanel Visibility="{Binding HasRestoreFile, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                        <TextBlock Text="恢复模式：" VerticalAlignment="Center"
                                                   Foreground="{DynamicResource TextSecondary}" FontSize="12"/>
                                        <ComboBox ItemsSource="{Binding RestoreModeOptions}"
                                                  SelectedValue="{Binding SelectedRestoreMode}"
                                                  SelectedValuePath="Value"
                                                  DisplayMemberPath="Label"
                                                  Width="170" Height="28" Margin="8,0,0,0"/>
                                    </StackPanel>
                                    <Button Content="执行恢复" Style="{StaticResource DangerBtn}"
                                            Command="{Binding RestoreCommand}"
                                            Height="34" FontSize="13" FontWeight="Bold"
                                            Padding="20,4" Margin="0,8,0,0"/>
                                </StackPanel>
                            </StackPanel>
                        </GroupBox>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
</UserControl>