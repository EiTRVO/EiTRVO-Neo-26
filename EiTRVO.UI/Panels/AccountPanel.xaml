<UserControl x:Class="EiTRVO.UI.Panels.AccountPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

            <Grid >
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="24,20,24,8">
                    <TextBlock Text="账号管理" FontSize="18"
                               FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimary}"/>
                    <TextBlock Text="管理微软/Yggdrasil 账号登录"
                               FontSize="12" Margin="0,4,0,0"
                               Foreground="{DynamicResource TextSecondary}"/>
                </StackPanel>

                <StackPanel Grid.Row="1" Orientation="Horizontal"
                            Margin="24,0,24,6">
                    <Button x:Name="btnAddAccount"
                            Content="添加微软账号"
                            Style="{StaticResource CardBtn}"
                            Height="30" Padding="10,3"
                            Foreground="{DynamicResource AccentBlue}"
                            Command="{Binding AddMicrosoftCommand}"/>
                    <Button x:Name="btnAddYggdrasilAccount"
                            Content="添加 Yggdrasil 账号"
                            Style="{StaticResource CardBtn}"
                            Height="30" Padding="10,3" Margin="8,0,0,0"
                            Foreground="{DynamicResource AccentBlue}"
                            Command="{Binding ToggleYggdrasilFormCommand}"/>
                </StackPanel>

                <!-- Yggdrasil auth form -->
                <Border x:Name="pnlYggdrasilForm" Grid.Row="2"
                        Visibility="{Binding IsYggdrasilFormVisible, Converter={StaticResource BoolToVisibilityConverter}}"
                        Background="{DynamicResource Surface}"
                        CornerRadius="8" Padding="16"
                        Margin="24,4">
                    <StackPanel>
                        <TextBlock Text="Yggdrasil 第三方验证"
                                   FontWeight="Bold" FontSize="14"
                                   Foreground="{DynamicResource TextPrimary}"
                                   Margin="0,0,0,12"/>
                        <TextBlock Text="验证服务器" FontWeight="SemiBold"
                                   FontSize="12" Margin="0,0,0,4"
                                   Foreground="{DynamicResource TextSecondary}"/>
                        <TextBox x:Name="txtYggdrasilServerUrl"
                                 Height="32" Margin="0,0,0,10"
                                 Text="{Binding YggdrasilServerUrl, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Foreground="{DynamicResource TextPrimary}"/>
                        <TextBlock Text="邮箱" FontWeight="SemiBold"
                                   FontSize="12" Margin="0,0,0,4"
                                   Foreground="{DynamicResource TextSecondary}"/>
                        <TextBox x:Name="txtYggdrasilEmail"
                                 Height="32" Margin="0,0,0,10"
                                 Text="{Binding YggdrasilEmail, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Foreground="{DynamicResource TextPrimary}"/>
                        <TextBlock Text="密码" FontWeight="SemiBold"
                                   FontSize="12" Margin="0,0,0,4"
                                   Foreground="{DynamicResource TextSecondary}"/>
                        <PasswordBox x:Name="txtYggdrasilPassword"
                                     Height="32" Margin="0,0,0,12"
                                     Foreground="{DynamicResource TextPrimary}"
                                     PasswordChanged="TxtYggdrasilPassword_PasswordChanged"/>
                        <TextBlock x:Name="txtYggdrasilStatus"
                                   Foreground="{DynamicResource AccentOrange}"
                                   TextWrapping="Wrap" Margin="0,0,0,12"
                                   Text="{Binding YggdrasilStatus}"
                                   Visibility="{Binding YggdrasilStatus, Converter={StaticResource StringNotEmptyToVisibilityConverter}}"/>
                        <StackPanel Orientation="Horizontal">
                            <Button x:Name="btnYggdrasilLogin"
                                    Content="登录"
                                    Style="{StaticResource PrimaryBtn}"
                                    Height="28" Padding="12,3"
                                    Command="{Binding YggdrasilLoginCommand}"/>
                            <Button x:Name="btnYggdrasilCancel"
                                    Content="取消"
                                    Style="{StaticResource DangerBtn}"
                                    Height="28" Padding="10,3" Margin="10,0,0,0"
                                    Command="{Binding CancelYggdrasilCommand}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Device code area -->
                <Border x:Name="pnlDeviceCodeArea" Grid.Row="3"
                        Visibility="{Binding IsDeviceCodeVisible, Converter={StaticResource BoolToVisibilityConverter}}"
                        Background="{DynamicResource Surface}"
                        CornerRadius="8" Padding="16"
                        Margin="24,4">
                    <StackPanel>
                        <TextBlock Text="Microsoft 设备代码认证"
                                   FontWeight="Bold" FontSize="14"
                                   Foreground="{DynamicResource TextPrimary}"
                                   Margin="0,0,0,12"/>
                        <TextBlock Text="请在浏览器中打开以下链接（点击按钮自动打开）："
                                   Foreground="{DynamicResource TextSecondary}"
                                   Margin="0,0,0,6"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <TextBlock x:Name="txtVerificationUri"
                                       Text="{Binding VerificationUri}"
                                       Foreground="{DynamicResource AccentBlue}"
                                       FontWeight="SemiBold" FontSize="13"
                                       VerticalAlignment="Center"
                                       TextWrapping="Wrap" MaxWidth="360"/>
                            <Button Content="打开网页"
                                    Style="{StaticResource PrimaryBtn}"
                                    Height="28" FontSize="12" Padding="12,2"
                                    Margin="10,0,0,0"
                                    Command="{Binding OpenBrowserCommand}"/>
                        </StackPanel>
                        <TextBlock Text="并输入以下代码（点击可复制）："
                                   Foreground="{DynamicResource TextSecondary}"
                                   Margin="0,8,0,6"/>
                        <TextBlock x:Name="txtUserCode"
                                   Text="{Binding UserCode}"
                                   FontSize="28" FontWeight="Bold"
                                   Foreground="{DynamicResource AccentGreen}"
                                   Margin="0,0,0,12"
                                   Cursor="Hand"
                                   MouseLeftButtonDown="TxtUserCode_Click"/>
                        <TextBlock x:Name="txtDeviceStatus"
                                   Text="{Binding DeviceStatus}"
                                   Foreground="{DynamicResource AccentOrange}"
                                   TextWrapping="Wrap" Margin="0,0,0,12"/>
                        <Button x:Name="btnCancelDeviceCode"
                                Content="取消认证"
                                Style="{StaticResource DangerBtn}"
                                Height="28" Padding="10,3"
                                Command="{Binding CancelAuthCommand}"/>
                    </StackPanel>
                </Border>

                <ListBox Grid.Row="4" x:Name="lstAccounts"
                         SelectionMode="Single"
                         ItemsSource="{Binding Accounts}"
                         ItemTemplate="{StaticResource AccountCardTemplate}"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         Margin="24,4,24,16">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="HorizontalContentAlignment"
                                    Value="Stretch"/>
                            <Setter Property="Padding" Value="0"/>
                        </Style>
                    </ListBox.ItemContainerStyle>
                </ListBox>
            </Grid>
</UserControl>