<UserControl x:Class="EiTRVO.UI.Panels.ModpackDownloadPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header: back button + title -->
        <Border Grid.Row="0" Padding="24,16,24,10"
                BorderBrush="{DynamicResource SidebarBorder}"
                BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal">
                <Button Content="← 返回"
                        Style="{StaticResource CardBtn}"
                        Foreground="{DynamicResource AccentBlue}"
                        Height="28" FontSize="12" Padding="10,3"
                        Command="{Binding GoBackCommand}"/>
                <TextBlock Text="整合包下载"
                           FontSize="20" FontWeight="Bold"
                           Foreground="{DynamicResource TextPrimary}"
                           VerticalAlignment="Center"
                           Margin="16,0,0,0"/>
            </StackPanel>
        </Border>

        <!-- Body: search + results -->
        <Grid Grid.Row="1" Margin="24,12,24,6">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Search bar row: MC version selector + search textbox + search button -->
            <Grid Grid.Row="0" Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- MC Version selector -->
                <ComboBox Grid.Column="0" Width="130" Height="32"
                          ItemsSource="{Binding MinecraftVersions}"
                          SelectedItem="{Binding SelectedMcVersion, Mode=TwoWay}"
                          Margin="0,0,10,0"
                          FontSize="13"
                          Foreground="{DynamicResource TextPrimary}"
                          Background="{DynamicResource Surface}"
                          BorderBrush="{DynamicResource InputBorder}"/>

                <!-- Search text input -->
                <TextBox Grid.Column="1" Height="32"
                         Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                         FontSize="13"
                         Foreground="{DynamicResource TextPrimary}"
                         Background="{DynamicResource Surface}"
                         BorderBrush="{DynamicResource InputBorder}"
                         Padding="10,4" VerticalContentAlignment="Center"/>

                <!-- Search button -->
                <Button Grid.Column="2" Content="搜索"
                        Style="{StaticResource PrimaryBtn}"
                        Height="32" FontSize="13" Padding="16,0"
                        Margin="10,0,0,0"
                        Command="{Binding SearchModpacksCommand}"/>
            </Grid>

            <!-- Results count / loading indicator -->
            <StackPanel Grid.Row="1" Margin="0,0,0,8">
                <TextBlock FontSize="12"
                           Foreground="{DynamicResource TextSecondary}"
                           Visibility="{Binding IsSearching, Converter={StaticResource BoolToVisibilityConverter}}"
                           Text="搜索中..."/>
                <TextBlock FontSize="12"
                           Foreground="{DynamicResource TextSecondary}"
                           Visibility="{Binding IsSearching, Converter={StaticResource BoolInvertConverter}}">
                    <Run Text="找到 "/>
                    <Run Text="{Binding TotalSearchResults}" FontWeight="SemiBold"/>
                    <Run Text=" 个结果"/>
                </TextBlock>
            </StackPanel>

            <!-- No results -->
            <TextBlock Grid.Row="2"
                       Text="没有找到匹配的整合包。请尝试其他关键词。"
                       FontSize="13"
                       Foreground="{DynamicResource TextMuted}"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       Visibility="{Binding HasNoResults, Converter={StaticResource BoolToVisibilityConverter}}"/>

            <!-- Results list -->
            <ListBox Grid.Row="2" x:Name="lstModpackSearchResults"
                     SelectionMode="Single"
                     ItemsSource="{Binding SearchResults}"
                     ItemTemplate="{StaticResource ModpackDownloadCardTemplate}"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     Visibility="{Binding HasNoResults, Converter={StaticResource BoolInvertConverter}}">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="Padding" Value="0"/>
                    </Style>
                </ListBox.ItemContainerStyle>
            </ListBox>

            <!-- Modrinth attribution -->
            <TextBlock Grid.Row="3"
                       Text="整合包数据来自 Modrinth"
                       FontSize="10"
                       Foreground="{DynamicResource TextMuted}"
                       HorizontalAlignment="Center"
                       Margin="0,10,0,4"/>
        </Grid>
    </Grid>
</UserControl>
