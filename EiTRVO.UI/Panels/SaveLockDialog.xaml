<Window x:Class="EiTRVO.UI.Panels.SaveLockDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="锁定存档" MinHeight="400" Height="520" Width="460"
        FontFamily="{StaticResource CustomFont}"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False"
        ResizeMode="NoResize"
        Background="{DynamicResource WindowBg}">

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20">
        <StackPanel>
            <!-- Title -->
            <TextBlock x:Name="lblTitle" FontSize="16" FontWeight="Bold"
                       Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,16"
                       TextWrapping="Wrap"/>

            <!-- Password -->
            <TextBlock Text="密码" Foreground="{DynamicResource TextSecondary}" FontSize="12"/>
            <PasswordBox x:Name="txtPassword" Height="32" FontSize="13"
                         Background="{DynamicResource Surface}"
                         BorderBrush="{DynamicResource PanelBorder}"
                         Margin="0,2,0,10"/>

            <!-- Confirm Password -->
            <TextBlock Text="确认密码" Foreground="{DynamicResource TextSecondary}" FontSize="12"/>
            <PasswordBox x:Name="txtConfirmPassword" Height="32" FontSize="13"
                         Background="{DynamicResource Surface}"
                         BorderBrush="{DynamicResource PanelBorder}"
                         Margin="0,2,0,10"/>

            <!-- Lock Mode -->
            <TextBlock Text="加密模式" Foreground="{DynamicResource TextSecondary}" FontSize="12"/>
            <RadioButton x:Name="rbOneTime" GroupName="LockMode" Margin="0,4"
                         Foreground="{DynamicResource TextPrimary}" IsChecked="True">
                <TextBlock>
                    <Run Text="一次性"/>
                    <Run Text=" -- 解锁后保持明文" Foreground="{DynamicResource TextMuted}"/>
                </TextBlock>
            </RadioButton>
            <RadioButton x:Name="rbPermanent" GroupName="LockMode" Margin="0,2,0,10"
                         Foreground="{DynamicResource TextPrimary}">
                <TextBlock>
                    <Run Text="永久"/>
                    <Run Text=" -- 游戏退出后自动重新锁定" Foreground="{DynamicResource TextMuted}"/>
                </TextBlock>
            </RadioButton>

            <!-- Password Hint -->
            <TextBlock Text="密码提示（可选，帮助你回忆密码）"
                       Foreground="{DynamicResource TextSecondary}" FontSize="12"/>
            <TextBox x:Name="txtPasswordHint" Height="28" FontSize="12" Margin="0,2,0,2"
                     Background="{DynamicResource Surface}"
                     BorderBrush="{DynamicResource PanelBorder}"/>
            <TextBlock Text="提示将以明文存储在 .savenc 文件中，不要在其中直接包含密码本身"
                       FontSize="11" Foreground="{DynamicResource TextMuted}" Margin="0,0,0,12"
                       TextWrapping="Wrap"/>

            <!-- Recovery Options -->
            <TextBlock Text="密钥备份" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimary}" FontSize="13"
                       Margin="0,4,0,8"/>

            <CheckBox x:Name="chkLocalBackup" Margin="0,2,0,4" IsChecked="True"
                      Foreground="{DynamicResource TextPrimary}">
                <TextBlock>
                    <Run Text="保存密钥备份文件 (.savkey)" FontWeight="SemiBold"/>
                    <LineBreak/>
                    <Run Text="DPAPI 加密，仅当前 Windows 用户可解密"
                         Foreground="{DynamicResource TextMuted}" FontSize="11"/>
                </TextBlock>
            </CheckBox>

            <!-- MS Account only: .savrec -->
            <StackPanel x:Name="pnlHasMsAccount" Visibility="Collapsed">
                <CheckBox x:Name="chkRecovery" Margin="0,2,0,10" IsChecked="True"
                          Foreground="{DynamicResource TextPrimary}">
                    <TextBlock>
                        <Run Text="导出恢复文件 (.savrec)" FontWeight="SemiBold"/>
                        <LineBreak/>
                        <Run Text="可保存到 USB 设备或手机，换设备可恢复"
                             Foreground="{DynamicResource TextMuted}" FontSize="11"/>
                    </TextBlock>
                </CheckBox>
            </StackPanel>

            <!-- No MS Account -->
            <StackPanel x:Name="pnlNoMsAccount" Visibility="Collapsed">
                <CheckBox Content="导出恢复文件 (需要微软账户)" IsEnabled="False"
                          Foreground="{DynamicResource TextMuted}" Margin="0,2,0,6" FontSize="11"/>
                <TextBlock Text="未登录微软账户，.savrec 不可用。密钥备份文件 (.savkey) 绑"
                           FontSize="11" Foreground="{DynamicResource TextMuted}"
                           TextWrapping="Wrap" Margin="0,0,0,10"/>
                <TextBlock Text="定当前 Windows 用户，换设备或重装系统后无法恢复。建议登"
                           FontSize="11" Foreground="{DynamicResource AccentRed}"
                           TextWrapping="Wrap" Margin="0,0,0,4"/>
                <TextBlock Text="录微软账户以启用跨设备恢复。"
                           FontSize="11" Foreground="{DynamicResource AccentRed}"
                           TextWrapping="Wrap" Margin="0,0,0,10"/>
            </StackPanel>

            <!-- Separator -->
            <Border Height="1" Background="{DynamicResource SidebarBorder}" Margin="0,4,0,12"/>

            <!-- Error -->
            <TextBlock x:Name="lblError" FontSize="12"
                       Foreground="{DynamicResource AccentRed}"
                       Visibility="Collapsed" Margin="0,0,0,8"
                       TextWrapping="Wrap"/>

            <!-- Buttons -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="取消"
                        Style="{StaticResource CardBtn}"
                        Height="30" FontSize="12" Padding="14,3"
                        Margin="0,0,8,0" IsCancel="True"/>
                <Button Content="确认锁定"
                        Style="{StaticResource PrimaryBtn}"
                        Height="30" FontSize="12" Padding="14,3"
                        Click="BtnConfirm_Click"/>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Window>
