<Window x:Class="EiTRVO.UI.Panels.PasswordPromptDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="密码验证" MinHeight="200" Height="260" Width="420"
        FontFamily="{StaticResource CustomFont}"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False"
        ResizeMode="NoResize"
        Background="{DynamicResource WindowBg}">

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20">
        <StackPanel>
            <!-- Title -->
            <TextBlock x:Name="lblTitle" FontSize="15" FontWeight="Bold"
                       Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,10"
                       TextWrapping="Wrap"/>

            <!-- Save / Instance info -->
            <TextBlock x:Name="lblInfo" FontSize="12"
                       Foreground="{DynamicResource TextMuted}"
                       Margin="0,0,0,14" TextWrapping="Wrap"/>

            <!-- Password input -->
            <TextBlock Text="请输入存档密码:"
                       Foreground="{DynamicResource TextSecondary}" FontSize="12"
                       Margin="0,0,0,4"/>
            <PasswordBox x:Name="txtPassword" Height="32" FontSize="13"
                         Background="{DynamicResource Surface}"
                         BorderBrush="{DynamicResource PanelBorder}"
                         Margin="0,0,0,4"/>

            <TextBlock Text="密码仅用于即时验证，不会存储。"
                       FontSize="11" Foreground="{DynamicResource TextMuted}"
                       Margin="0,0,0,12"/>

            <!-- Error -->
            <TextBlock x:Name="lblError" FontSize="12"
                       Foreground="{DynamicResource AccentRed}"
                       Visibility="Collapsed" Margin="0,0,0,8"
                       TextWrapping="Wrap"/>

            <!-- Buttons -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="取消"
                        Style="{StaticResource CardBtn}"
                        Height="30" FontSize="12" Padding="14,3"
                        Margin="0,0,8,0" IsCancel="True"/>
                <Button x:Name="btnConfirm"
                        Style="{StaticResource PrimaryBtn}"
                        Height="30" FontSize="12" Padding="14,3"
                        Click="BtnConfirm_Click"/>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Window>
