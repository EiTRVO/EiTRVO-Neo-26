<UserControl x:Class="EiTRVO.UI.Panels.HomePanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

            <Grid Margin="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="24,20,24,12">
                    <TextBlock Text="EiTRVO Management Panel"
                               FontSize="22" FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimary}"/>
                    <TextBlock Text="选择实例，启动游戏"
                               FontSize="13"
                               Foreground="{DynamicResource TextSecondary}"
                               Margin="0,4,0,0"/>
                </StackPanel>

                <StackPanel Grid.Row="1" Margin="24,0">
                    <TextBlock Text="游戏实例" FontWeight="SemiBold"
                               Margin="0,0,0,4" FontSize="12"
                               Foreground="{DynamicResource TextSecondary}"/>
                    <ComboBox x:Name="cmbVersions" Height="34"
                              Margin="0,0,0,14"
                              ItemsSource="{Binding LocalInstances}"
                              SelectedItem="{Binding SelectedInstance, Mode=TwoWay}"
                              DisplayMemberPath="DisplayText"/>

                    <CheckBox x:Name="chkUseMicrosoft"
                              Content="使用可验证账号登录"
                              Style="{StaticResource ToggleSwitchStyle}"
                              Margin="0,0,0,10"
                              IsChecked="{Binding UseMicrosoft, Mode=TwoWay}"/>

                    <TextBlock x:Name="lblPlayerName" Text="玩家名"
                               FontWeight="SemiBold" FontSize="12"
                               Margin="0,0,0,4"
                               Foreground="{DynamicResource TextSecondary}"
                               Visibility="{Binding IsOfflineMode, Converter={StaticResource BoolToVisibilityConverter}}"/>
                    <TextBox x:Name="txtPlayerName" Height="34"
                             Text="{Binding PlayerName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,14"
                             Visibility="{Binding IsOfflineMode, Converter={StaticResource BoolToVisibilityConverter}}"/>

                    <ComboBox x:Name="cmbAccounts"
                              Visibility="{Binding IsMicrosoftMode, Converter={StaticResource BoolToVisibilityConverter}}"
                              Height="34" Margin="0,0,0,14"
                              ItemsSource="{Binding Accounts}"
                              SelectedItem="{Binding SelectedAccount, Mode=TwoWay}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding DisplayText}"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Text=" ["
                                               VerticalAlignment="Center"
                                               Foreground="{DynamicResource TextMuted}"
                                               FontSize="11"/>
                                    <TextBlock Text="{Binding AccountTypeLabel}"
                                               VerticalAlignment="Center"
                                               Foreground="{DynamicResource AccentBlue}"
                                               FontSize="11"/>
                                    <TextBlock Text="]"
                                               VerticalAlignment="Center"
                                               Foreground="{DynamicResource TextMuted}"
                                               FontSize="11"/>
                                </StackPanel>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </StackPanel>

                <Button Grid.Row="2" x:Name="btnLaunch"
                        Content="启动游戏"
                        Style="{StaticResource LaunchBtn}"
                        Width="260" Margin="24,14,0,0"
                        Command="{Binding LaunchCommand}"
                        IsEnabled="{Binding IsLaunching, Converter={StaticResource BoolInvertConverter}}"/>
            </Grid>
</UserControl>