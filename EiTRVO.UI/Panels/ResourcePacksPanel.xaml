<UserControl x:Class="EiTRVO.UI.Panels.ResourcePacksPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

            <Grid >
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Header: back + instance name -->
                <Border Grid.Row="0" Padding="24,16,24,10"
                        BorderBrush="{DynamicResource SidebarBorder}"
                        BorderThickness="0,0,0,1">
                    <StackPanel Orientation="Horizontal">
                        <Button Content="← 返回"
                                Style="{StaticResource CardBtn}"
                                Foreground="{DynamicResource AccentBlue}"
                                Height="28" FontSize="12" Padding="10,3"
                                Command="{Binding GoBackCommand}"/>
                        <TextBlock Text="{Binding InstanceName}"
                                   FontSize="20" FontWeight="Bold"
                                   Foreground="{DynamicResource TextPrimary}"
                                   VerticalAlignment="Center"
                                   Margin="16,0,0,0"/>
                        <TextBlock Text="  资源 &amp; 光影"
                                   FontSize="16"
                                   Foreground="{DynamicResource TextSecondary}"
                                   VerticalAlignment="Center"
                                   Margin="8,0,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Body: sidebar + content -->
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="160"/>
                        <ColumnDefinition Width="2"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Left sidebar -->
                    <Border Grid.Column="0"
                            Background="{DynamicResource SidebarBg}">
                        <StackPanel Margin="6,8,6,6">
                            <Button Tag="resource-local"
                                    Command="{Binding SelectTabCommand}"
                                    CommandParameter="resource-local">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource SidebarNavButton}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedTab}" Value="resource-local">
                                                <Setter Property="Background" Value="{DynamicResource MenuActiveBg}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <TextBlock Text="资源包管理" FontSize="13"
                                           Foreground="{DynamicResource TextPrimary}"/>
                            </Button>
                            <Button Tag="shader-local"
                                    Command="{Binding SelectTabCommand}"
                                    CommandParameter="shader-local">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource SidebarNavButton}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedTab}" Value="shader-local">
                                                <Setter Property="Background" Value="{DynamicResource MenuActiveBg}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <TextBlock Text="光影包管理" FontSize="13"
                                           Foreground="{DynamicResource TextPrimary}"/>
                            </Button>
                            <Button Tag="resource-download"
                                    Command="{Binding SelectTabCommand}"
                                    CommandParameter="resource-download">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource SidebarNavButton}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedTab}" Value="resource-download">
                                                <Setter Property="Background" Value="{DynamicResource MenuActiveBg}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <TextBlock Text="资源包下载" FontSize="13"
                                           Foreground="{DynamicResource TextPrimary}"/>
                            </Button>
                            <Button Tag="shader-download"
                                    Command="{Binding SelectTabCommand}"
                                    CommandParameter="shader-download">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource SidebarNavButton}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedTab}" Value="shader-download">
                                                <Setter Property="Background" Value="{DynamicResource MenuActiveBg}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <TextBlock Text="光影包下载" FontSize="13"
                                           Foreground="{DynamicResource TextPrimary}"/>
                            </Button>
                        </StackPanel>
                    </Border>

                    <!-- Thin divider -->
                    <Border Grid.Column="1"
                            Background="{DynamicResource SidebarBorder}"/>

                    <!-- Content area -->
                    <Grid Grid.Column="2"
                          Background="{DynamicResource WindowBg}">
                        <Grid Margin="20,12">

                        <!-- 资源包管理 -->
                        <Grid Visibility="{Binding IsResourceLocalVisible, Converter={StaticResource BoolToVisibilityConverter}}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- 文件夹不存在 -->
                            <TextBlock Grid.Row="0"
                                       Text="该实例不支持资源包。"
                                       FontSize="13"
                                       Foreground="{DynamicResource TextMuted}"
                                       Margin="0,0,0,8"
                                       Visibility="{Binding ResourceFolderExists, Converter={StaticResource BoolInvertConverter}}"/>

                            <!-- 文件夹存在时的内容 -->
                            <Grid Grid.Row="1"
                                  Visibility="{Binding ResourceFolderExists, Converter={StaticResource BoolToVisibilityConverter}}">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <!-- 导入按钮 -->
                                <Button Grid.Row="0" Content="导入资源包"
                                        Style="{StaticResource PrimaryBtn}"
                                        Height="28" FontSize="12" Padding="12,3"
                                        HorizontalAlignment="Left"
                                        Margin="0,0,0,8"
                                        Command="{Binding ImportResourcePackCommand}"/>

                                <!-- 空状态 -->
                                <TextBlock Grid.Row="1"
                                           Text="暂无资源包。请将 .zip 文件或解压的资源包文件夹放入 resourcepacks 目录。"
                                           FontSize="13"
                                           Foreground="{DynamicResource TextMuted}"
                                           Margin="0,0,0,8"
                                           Visibility="{Binding IsResourceEmpty, Converter={StaticResource BoolToVisibilityConverter}}"/>

                                <!-- 资源包列表 -->
                                <ListBox Grid.Row="2" x:Name="lstResourcePacks"
                                         SelectionMode="Single"
                                         ItemsSource="{Binding ResourcePacks}"
                                         ItemTemplate="{StaticResource ResourceCardTemplate}"
                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                         Visibility="{Binding IsResourceEmpty, Converter={StaticResource BoolInvertConverter}}">
                                    <ListBox.ItemContainerStyle>
                                        <Style TargetType="ListBoxItem">
                                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                            <Setter Property="Padding" Value="0"/>
                                        </Style>
                                    </ListBox.ItemContainerStyle>
                                </ListBox>
                            </Grid>
                        </Grid>

                        <!-- 光影包管理 -->
                        <Grid Visibility="{Binding IsShaderLocalVisible, Converter={StaticResource BoolToVisibilityConverter}}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- 文件夹不存在 -->
                            <TextBlock Grid.Row="0"
                                       Text="该实例不支持光影包。"
                                       FontSize="13"
                                       Foreground="{DynamicResource TextMuted}"
                                       Margin="0,0,0,8"
                                       Visibility="{Binding ShaderFolderExists, Converter={StaticResource BoolInvertConverter}}"/>

                            <!-- 文件夹存在时的内容 -->
                            <Grid Grid.Row="1"
                                  Visibility="{Binding ShaderFolderExists, Converter={StaticResource BoolToVisibilityConverter}}">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <!-- 导入按钮 -->
                                <Button Grid.Row="0" Content="导入光影包"
                                        Style="{StaticResource PrimaryBtn}"
                                        Height="28" FontSize="12" Padding="12,3"
                                        HorizontalAlignment="Left"
                                        Margin="0,0,0,8"
                                        Command="{Binding ImportShaderPackCommand}"/>

                                <!-- 空状态 -->
                                <TextBlock Grid.Row="1"
                                           Text="暂无光影包。请将光影包 .zip 文件放入 shaderpacks 目录。"
                                           FontSize="13"
                                           Foreground="{DynamicResource TextMuted}"
                                           Margin="0,0,0,8"
                                           Visibility="{Binding IsShaderEmpty, Converter={StaticResource BoolToVisibilityConverter}}"/>

                                <!-- 光影包列表 -->
                                <ListBox Grid.Row="2" x:Name="lstShaderPacks"
                                         SelectionMode="Single"
                                         ItemsSource="{Binding ShaderPacks}"
                                         ItemTemplate="{StaticResource ShaderCardTemplate}"
                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                         Visibility="{Binding IsShaderEmpty, Converter={StaticResource BoolInvertConverter}}">
                                    <ListBox.ItemContainerStyle>
                                        <Style TargetType="ListBoxItem">
                                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                            <Setter Property="Padding" Value="0"/>
                                        </Style>
                                    </ListBox.ItemContainerStyle>
                                </ListBox>
                            </Grid>
                        </Grid>

                        <!-- 资源包下载 -->
                        <Grid Visibility="{Binding IsResourceDownloadVisible, Converter={StaticResource BoolToVisibilityConverter}}">
                            <!-- 不支持 -->
                            <TextBlock Text="该实例不支持资源包。"
                                       FontSize="14"
                                       Foreground="{DynamicResource TextMuted}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Visibility="{Binding ResourceFolderExists, Converter={StaticResource BoolInvertConverter}}"/>

                            <!-- 下载内容 -->
                            <Grid Visibility="{Binding ResourceFolderExists, Converter={StaticResource BoolToVisibilityConverter}}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0" Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0" Height="32"
                                         Text="{Binding ResourceSearchQuery, UpdateSourceTrigger=PropertyChanged}"
                                         FontSize="13"
                                         Foreground="{DynamicResource TextPrimary}"
                                         Background="{DynamicResource Surface}"
                                         BorderBrush="{DynamicResource InputBorder}"
                                         Padding="10,4" VerticalContentAlignment="Center">
                                    <TextBox.Resources>
                                        <Style TargetType="Border">
                                            <Setter Property="CornerRadius" Value="6,0,0,6"/>
                                        </Style>
                                    </TextBox.Resources>
                                </TextBox>
                                <Button Grid.Column="1" Content="搜索"
                                        Style="{StaticResource PrimaryBtn}"
                                        Height="32" FontSize="13" Padding="16,0"
                                        Margin="16,0,0,0"
                                        Command="{Binding SearchResourcePacksCommand}">
                                    <Button.Resources>
                                        <Style TargetType="Border">
                                            <Setter Property="CornerRadius" Value="0,6,6,0"/>
                                        </Style>
                                    </Button.Resources>
                                </Button>
                            </Grid>

                            <StackPanel Grid.Row="1" Margin="0,0,0,8">
                                <TextBlock FontSize="12"
                                           Foreground="{DynamicResource TextSecondary}"
                                           Visibility="{Binding IsResourceSearching, Converter={StaticResource BoolToVisibilityConverter}}"
                                           Text="搜索中..."/>
                                <TextBlock FontSize="12"
                                           Foreground="{DynamicResource TextSecondary}"
                                           Visibility="{Binding IsResourceSearching, Converter={StaticResource BoolInvertConverter}}">
                                    <Run Text="找到 "/>
                                    <Run Text="{Binding ResourceTotalResults}" FontWeight="SemiBold"/>
                                    <Run Text=" 个结果"/>
                                </TextBlock>
                            </StackPanel>

                            <TextBlock Grid.Row="2"
                                       Text="没有找到匹配的资源包。请尝试其他关键词。"
                                       FontSize="13"
                                       Foreground="{DynamicResource TextMuted}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Visibility="{Binding ResourceHasNoResults, Converter={StaticResource BoolToVisibilityConverter}}"/>

                            <ListBox Grid.Row="2" x:Name="lstResourceSearchResults"
                                     SelectionMode="Single"
                                     ItemsSource="{Binding ResourceSearchResults}"
                                     ItemTemplate="{StaticResource ResourcePackDownloadCardTemplate}"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                     Visibility="{Binding ResourceHasNoResults, Converter={StaticResource BoolInvertConverter}}">
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                        <Setter Property="Padding" Value="0"/>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                            </ListBox>

                            <TextBlock Grid.Row="3"
                                       Text="资源包数据来自 Modrinth"
                                       FontSize="10"
                                       Foreground="{DynamicResource TextMuted}"
                                       HorizontalAlignment="Center"
                                       Margin="0,10,0,4"/>
                            </Grid>
                        </Grid>

                        <!-- 光影包下载 -->
                        <Grid Visibility="{Binding IsShaderDownloadVisible, Converter={StaticResource BoolToVisibilityConverter}}">
                            <!-- 不支持 -->
                            <TextBlock Text="该实例不支持光影包。"
                                       FontSize="14"
                                       Foreground="{DynamicResource TextMuted}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Visibility="{Binding ShaderFolderExists, Converter={StaticResource BoolInvertConverter}}"/>

                            <!-- 下载内容 -->
                            <Grid Visibility="{Binding ShaderFolderExists, Converter={StaticResource BoolToVisibilityConverter}}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0" Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0" Height="32"
                                         Text="{Binding ShaderSearchQuery, UpdateSourceTrigger=PropertyChanged}"
                                         FontSize="13"
                                         Foreground="{DynamicResource TextPrimary}"
                                         Background="{DynamicResource Surface}"
                                         BorderBrush="{DynamicResource InputBorder}"
                                         Padding="10,4" VerticalContentAlignment="Center">
                                    <TextBox.Resources>
                                        <Style TargetType="Border">
                                            <Setter Property="CornerRadius" Value="6,0,0,6"/>
                                        </Style>
                                    </TextBox.Resources>
                                </TextBox>
                                <Button Grid.Column="1" Content="搜索"
                                        Style="{StaticResource PrimaryBtn}"
                                        Height="32" FontSize="13" Padding="16,0"
                                        Margin="16,0,0,0"
                                        Command="{Binding SearchShaderPacksCommand}">
                                    <Button.Resources>
                                        <Style TargetType="Border">
                                            <Setter Property="CornerRadius" Value="0,6,6,0"/>
                                        </Style>
                                    </Button.Resources>
                                </Button>
                            </Grid>

                            <StackPanel Grid.Row="1" Margin="0,0,0,8">
                                <TextBlock FontSize="12"
                                           Foreground="{DynamicResource TextSecondary}"
                                           Visibility="{Binding IsShaderSearching, Converter={StaticResource BoolToVisibilityConverter}}"
                                           Text="搜索中..."/>
                                <TextBlock FontSize="12"
                                           Foreground="{DynamicResource TextSecondary}"
                                           Visibility="{Binding IsShaderSearching, Converter={StaticResource BoolInvertConverter}}">
                                    <Run Text="找到 "/>
                                    <Run Text="{Binding ShaderTotalResults}" FontWeight="SemiBold"/>
                                    <Run Text=" 个结果"/>
                                </TextBlock>
                            </StackPanel>

                            <TextBlock Grid.Row="2"
                                       Text="没有找到匹配的光影包。请尝试其他关键词。"
                                       FontSize="13"
                                       Foreground="{DynamicResource TextMuted}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Visibility="{Binding ShaderHasNoResults, Converter={StaticResource BoolToVisibilityConverter}}"/>

                            <ListBox Grid.Row="2" x:Name="lstShaderSearchResults"
                                     SelectionMode="Single"
                                     ItemsSource="{Binding ShaderSearchResults}"
                                     ItemTemplate="{StaticResource ShaderPackDownloadCardTemplate}"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                     Visibility="{Binding ShaderHasNoResults, Converter={StaticResource BoolInvertConverter}}">
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                        <Setter Property="Padding" Value="0"/>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                            </ListBox>

                            <TextBlock Grid.Row="3"
                                       Text="光影包数据来自 Modrinth"
                                       FontSize="10"
                                       Foreground="{DynamicResource TextMuted}"
                                       HorizontalAlignment="Center"
                                       Margin="0,10,0,4"/>
                        </Grid>

                        </Grid>
                        </Grid>
                    </Grid>
                </Grid>
            </Grid>
</UserControl>