<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ========================================== -->
    <!-- 所有 DataTemplate 集中管理                   -->
    <!-- 通过 MergedDictionary 在 MainWindow 中引用   -->
    <!-- ========================================== -->

    <!-- Manage Instance Card -->
    <DataTemplate x:Key="ManageCardTemplate">
        <Border Margin="4,2" Padding="14,10" CornerRadius="6"
                Background="{DynamicResource CardBg}"
                BorderBrush="{DynamicResource PanelBorder}"
                BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                        <TextBlock Text="{Binding DisplayText}" FontSize="13"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimary}"
                                   VerticalAlignment="Center"/>
                        <Border Background="{DynamicResource AccentGreen}"
                                CornerRadius="3" Padding="5,1"
                                Margin="8,0,0,0" VerticalAlignment="Center"
                                Visibility="{Binding ShowIsolatedBadge, Converter={StaticResource BoolToVisibilityConverter}}">
                            <TextBlock Text="隔离" FontSize="9"
                                       Foreground="White"
                                       FontWeight="SemiBold"/>
                        </Border>
                        <Border Background="{DynamicResource AccentBlue}"
                                CornerRadius="3" Padding="5,1" Margin="4,0,0,0"
                                VerticalAlignment="Center"
                                Visibility="{Binding ShowLoaderBadge, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                            <TextBlock Text="{Binding LoaderBadgeText, Mode=OneWay}"
                                       FontSize="9" Foreground="White"
                                       FontWeight="SemiBold"/>
                        </Border>
                    </StackPanel>
                    <TextBlock Text="{Binding PathDisplay, Mode=OneWay}"
                               FontSize="11"
                               Foreground="{DynamicResource TextSecondary}"
                               Margin="0,2,12,0"
                               TextTrimming="CharacterEllipsis"/>
                </StackPanel>

                <Button Grid.Column="1" Content="管理"
                        Style="{StaticResource CardBtn}"
                        Foreground="{DynamicResource AccentBlue}"
                        Height="26" FontSize="11" Padding="8,2"
                        Margin="0,0,6,0"
                        Command="{Binding DataContext.ManageInstanceCommand, ElementName=lstManagedInstances}"
                        CommandParameter="{Binding Name}"/>

                <Button Grid.Column="2" Content="打包"
                        Style="{StaticResource SuccessBtn}"
                        Height="26" FontSize="11" Padding="8,2"
                        Margin="0,0,6,0"
                        Command="{Binding DataContext.PackCommand, ElementName=lstManagedInstances}"
                        CommandParameter="{Binding Name}"/>

                <Button Grid.Column="3" Content="浏览"
                        Style="{StaticResource CardBtn}"
                        Height="26" FontSize="11" Padding="8,2"
                        Margin="0,0,6,0"
                        Command="{Binding DataContext.OpenFolderCommand, ElementName=lstManagedInstances}"
                        CommandParameter="{Binding Name}"/>

                <Button Grid.Column="4" Content="删除"
                        Style="{StaticResource DangerBtn}"
                        Height="26" FontSize="11" Padding="8,2"
                        Command="{Binding DataContext.DeleteCommand, ElementName=lstManagedInstances}"
                        CommandParameter="{Binding Name}"/>
            </Grid>
        </Border>
    </DataTemplate>

    <!-- Mod Card -->
    <DataTemplate x:Key="ModCardTemplate">
        <Border Margin="4,2" Padding="14,10" CornerRadius="6"
                Background="{DynamicResource CardBg}"
                BorderBrush="{DynamicResource PanelBorder}"
                BorderThickness="1">
