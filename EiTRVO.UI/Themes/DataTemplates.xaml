    <!-- Modpack Download Card -->
    <DataTemplate x:Key="ModpackDownloadCardTemplate">
        <Border Margin="4,2" Padding="14,10" CornerRadius="6"
                Background="{DynamicResource CardBg}"
                BorderBrush="{DynamicResource PanelBorder}"
                BorderThickness="1"
                HorizontalAlignment="Stretch">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="44"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Column="0" Grid.RowSpan="2"
                        Width="36" Height="36" CornerRadius="6"
                        Background="{DynamicResource DeepDark}"
                        VerticalAlignment="Top" Margin="0,2,0,0">
                    <Image Source="{Binding IconUrl}"
                           Width="36" Height="36"
                           Stretch="UniformToFill"/>
                </Border>

                <Grid Grid.Column="1" Grid.Row="0" Margin="10,0,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <DockPanel Grid.Column="0" VerticalAlignment="Center" ClipToBounds="True">
                        <!-- Loader badge (rightmost) -->
                        <Border DockPanel.Dock="Right"
                                Background="{DynamicResource AccentGreen}"
                                CornerRadius="3" Padding="5,1"
                                Margin="4,0,6,0" VerticalAlignment="Center"
                                Visibility="{Binding HasLoader, Converter={StaticResource BoolToVisibilityConverter}}">
                            <TextBlock Text="{Binding Loader}" FontSize="9"
                                       Foreground="White" FontWeight="SemiBold"/>
                        </Border>
                        <!-- MC Version badge -->
                        <Border DockPanel.Dock="Right"
                                Background="{DynamicResource AccentBlue}"
                                CornerRadius="3" Padding="5,1"
                                Margin="4,0,0,0" VerticalAlignment="Center"
                                Visibility="{Binding HasMcVersion, Converter={StaticResource BoolToVisibilityConverter}}">
                            <TextBlock Text="{Binding McVersion}" FontSize="9"
                                       Foreground="White" FontWeight="SemiBold"/>
                        </Border>
                        <!-- Downloads count -->
                        <TextBlock DockPanel.Dock="Right"
                                   Text="{Binding DownloadsDisplay, StringFormat='  {0} ↓'}"
                                   FontSize="11"
                                   Foreground="{DynamicResource TextMuted}"
                                   VerticalAlignment="Center"
                                   Margin="6,0,0,0"/>
                        <!-- Title: fills remaining space, auto-truncates -->
                        <TextBlock Text="{Binding Title}" FontSize="13"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimary}"
                                   TextTrimming="CharacterEllipsis"
                                   VerticalAlignment="Center"/>
                    </DockPanel>
                    <Button Grid.Column="1" Content="安装"
                            Style="{StaticResource PrimaryBtn}"
                            Height="26" FontSize="12" Padding="12,1"
                            Visibility="{Binding IsDownloading, Converter={StaticResource BoolInvertConverter}}"
                            Command="{Binding DataContext.InstallModpackCommand, ElementName=lstModpackSearchResults}"
                            CommandParameter="{Binding}"/>
                </Grid>

                <TextBlock Grid.Column="1" Grid.Row="1"
                           Text="{Binding Description}"
                           FontSize="11"
                           Foreground="{DynamicResource TextSecondary}"
                           Margin="10,3,0,0"
                           TextTrimming="CharacterEllipsis"
                           ToolTip="{Binding Description}"/>

                <TextBlock Grid.Column="1" Grid.Row="2"
                           FontSize="10"
                           Foreground="{DynamicResource TextMuted}"
                           Margin="10,3,0,0">
                    <Run Text="by "/>
                    <Run Text="{Binding Author}"/>
                </TextBlock>

                <Border Grid.Column="0" Grid.ColumnSpan="2"
                        Grid.Row="3" Margin="0,8,0,0"
                        Padding="10,8"
                        CornerRadius="5"
                        Background="{DynamicResource DeepDark}"
                        Visibility="{Binding IsDownloading, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0"
                                   Text="{Binding FileProgressDisplay}"
                                   FontSize="11"
                                   Foreground="{DynamicResource TextSecondary}"
                                   TextTrimming="CharacterEllipsis"
                                   ToolTip="{Binding FileProgressDisplay}"
                                   Margin="0,0,6,0"/>

                        <TextBlock Grid.Row="0" Grid.Column="0"
                                   Text="{Binding DownloadStatus}"
                                   FontSize="11"
                                   Foreground="{DynamicResource TextSecondary}"
                                   TextTrimming="CharacterEllipsis"
                                   ToolTip="{Binding DownloadStatus}"
                                   Margin="0,0,6,0"
                                   Visibility="{Binding HasFileProgress, Converter={StaticResource BoolInvertConverter}}"/>

                        <TextBlock Grid.Row="0" Grid.Column="1"
                                   FontSize="11"
                                   Foreground="{DynamicResource AccentBlue}"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"
                                   Text="{Binding DownloadProgress, StringFormat={}{0:F0}%}"/>

                        <Button Grid.Row="0" Grid.Column="2"
                                Content="取消"
                                ToolTip="取消安装"
                                Height="22" FontSize="10"
                                Padding="8,0" Margin="8,0,0,0"
                                Style="{StaticResource CardBtn}"
                                Foreground="{DynamicResource AccentRed}"
                                Command="{Binding DataContext.CancelInstallCommand, ElementName=lstModpackSearchResults}"
                                CommandParameter="{Binding}"/>

                        <ProgressBar Grid.Row="1" Grid.Column="0"
                                     Grid.ColumnSpan="3"
                                     Height="5" Margin="0,4,0,0"
                                     Value="{Binding DownloadProgress}"
                                     Minimum="0" Maximum="100"
                                     IsIndeterminate="{Binding HasFileProgress, Converter={StaticResource BoolInvertConverter}}"/>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </DataTemplate>

    <!-- Save Card -->
    <DataTemplate x:Key="SaveCardTemplate">
        <Border Margin="4,2" Padding="14,10" CornerRadius="6"
                Background="{DynamicResource CardBg}"
                BorderBrush="{DynamicResource PanelBorder}"
                BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="{Binding TitleDisplay, Mode=OneWay}"
                               FontSize="13" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimary}"
                               TextTrimming="CharacterEllipsis"
                               ToolTip="{Binding TitleDisplay}"/>
                    <TextBlock Text="{Binding LocationDisplay, Mode=OneWay}"
                               FontSize="11"
                               Foreground="{DynamicResource TextMuted}"
                               Margin="0,2,0,0"
                               TextTrimming="CharacterEllipsis"
                               ToolTip="{Binding LocationDisplay}"/>
                </StackPanel>

                <Button Grid.Column="1" Content="打包"
                        Style="{StaticResource SuccessBtn}"
                        Height="26" FontSize="11" Padding="8,2"
                        Margin="0,0,6,0"
                        Command="{Binding DataContext.ArchiveSaveCommand, ElementName=lstSaves}"
                        CommandParameter="{Binding}"/>

                <Button Grid.Column="2" Content="删除"
                        Style="{StaticResource DangerBtn}"
                        Height="26" FontSize="11" Padding="8,2"
                        Command="{Binding DataContext.DeleteSaveCommand, ElementName=lstSaves}"
                        CommandParameter="{Binding}"/>
            </Grid>
        </Border>
    </DataTemplate>

    <!-- Save Lock Card (存档锁 GroupBox) -->
    <DataTemplate x:Key="SaveLockCardTemplate">
        <Border Margin="4,2" Padding="14,10" CornerRadius="6"
                Background="{DynamicResource CardBg}"
                BorderBrush="{DynamicResource PanelBorder}"
                BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Left: save info -->
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                        <!-- Locked badge -->
                        <Border Background="{DynamicResource AccentBlue}"
                                CornerRadius="3" Padding="5,1"
                                Margin="0,0,6,0" VerticalAlignment="Center"
                                Visibility="{Binding IsLocked, Converter={StaticResource BoolToVisibilityConverter}}">
                            <TextBlock Text="已锁定" FontSize="9"
                                       Foreground="White" FontWeight="SemiBold"/>
                        </Border>
                        <!-- Save name -->
                        <TextBlock Text="{Binding TitleDisplay, Mode=OneWay}"
                                   FontSize="13" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimary}"
                                   TextTrimming="CharacterEllipsis"
                                   ToolTip="{Binding TitleDisplay}"
                                   VerticalAlignment="Center"/>
                        <!-- Lock mode badge -->
                        <Border Background="{DynamicResource AccentGreen}"
                                CornerRadius="3" Padding="5,1"
                                Margin="6,0,0,0" VerticalAlignment="Center"
                                Visibility="{Binding IsLocked, Converter={StaticResource BoolToVisibilityConverter}}">
                            <TextBlock Text="{Binding LockModeDisplay}" FontSize="9"
                                       Foreground="White" FontWeight="SemiBold"/>
                        </Border>
                        <!-- Not-backed-up warning badge -->
                        <Border Background="{DynamicResource AccentRed}"
                                CornerRadius="3" Padding="5,1"
                                Margin="4,0,0,0" VerticalAlignment="Center"
                                Visibility="{Binding ShowNotBackedUpBadge, Converter={StaticResource BoolToVisibilityConverter}}">
                            <TextBlock Text="未备份" FontSize="9"
                                       Foreground="White" FontWeight="SemiBold"/>
                        </Border>
                    </StackPanel>
                    <TextBlock Text="{Binding InfoDisplay, Mode=OneWay}"
                               FontSize="11"
                               Foreground="{DynamicResource TextMuted}"
                               Margin="0,2,0,0"
                               TextTrimming="CharacterEllipsis"
                               ToolTip="{Binding InfoDisplay}"/>
                </StackPanel>

                <!-- Right: 管理 button -->
                <Button Grid.Column="1" Content="管理"
                        Style="{StaticResource PrimaryBtn}"
                        Height="28" FontSize="12" Padding="14,4"
                        VerticalAlignment="Center"
                        Command="{Binding DataContext.OpenSaveLockDetailCommand, ElementName=lstSaveLocks}"
                        CommandParameter="{Binding}"/>
            </Grid>
        </Border>
    </DataTemplate>

    <!-- Account Card -->
    <DataTemplate x:Key="AccountCardTemplate">
        <Border Margin="4,2" Padding="14,10" CornerRadius="6"
                Background="{DynamicResource CardBg}"
                BorderBrush="{DynamicResource PanelBorder}"
                BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                        <TextBlock Text="{Binding DisplayText}" FontSize="13"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimary}"
                                   VerticalAlignment="Center"/>
                        <Border Background="{DynamicResource AccentBlue}"
                                CornerRadius="3" Padding="5,1"
                                Margin="8,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="{Binding AccountTypeLabel}"
                                       FontSize="9"
                                       Foreground="White"
                                       FontWeight="SemiBold"/>
                        </Border>
                    </StackPanel>
                    <TextBlock FontSize="11"
                               Foreground="{DynamicResource TextSecondary}"
                               Margin="0,2,0,0">
                        <Run Text="UUID: "/>
                        <Run Text="{Binding MaskedUUID, Mode=OneWay}" Foreground="{DynamicResource TextMuted}"
                             FontFamily="Consolas"/>
                    </TextBlock>
                    <TextBlock FontSize="10"
                               Foreground="{DynamicResource TextMuted}"
                               Margin="0,1,0,0">
                        <Run Text="上次使用："/>
                        <Run Text="{Binding LastUsedDisplay, Mode=OneWay}"/>
                    </TextBlock>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Button Content="管理"
                            Style="{StaticResource CardBtn}"
                            Height="26" FontSize="11" Padding="8,2"
                            Margin="0,0,8,0"
                            Foreground="{DynamicResource AccentBlue}"
                            Visibility="{Binding IsMicrosoftAccount, Converter={StaticResource BoolToVisibilityConverter}}"
                            Command="{Binding DataContext.ManageAccountCommand, ElementName=lstAccounts}"
                            CommandParameter="{Binding UUID}"/>
                    <Button Content="刷新"
                            Style="{StaticResource CardBtn}"
                            Height="26" FontSize="11" Padding="8,2"
                            Margin="0,0,8,0"
                            Foreground="{DynamicResource AccentGreen}"
                            Visibility="{Binding IsMicrosoftAccount, Converter={StaticResource BoolToVisibilityConverter}}"
                            Command="{Binding DataContext.RefreshTokenCommand, ElementName=lstAccounts}"
                            CommandParameter="{Binding UUID}"/>
                    <Button Content="删除"
                            Style="{StaticResource DangerBtn}"
                            Height="26" FontSize="11" Padding="8,2"
                            Command="{Binding DataContext.RemoveAccountCommand, ElementName=lstAccounts}"
                            CommandParameter="{Binding UUID}"/>
                </StackPanel>
            </Grid>
        </Border>
    </DataTemplate>

    <!-- Version Card with Download Button -->
    <DataTemplate x:Key="VersionCardTemplate">
        <Border x:Name="cardRoot" Margin="4,2" Padding="0" CornerRadius="6"
                Background="{DynamicResource CardBg}"
                BorderBrush="{DynamicResource PanelBorder}"
                BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="4"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Rectangle Grid.Column="0"
                           Fill="{Binding Type, Converter={StaticResource VersionTypeToBrushConverter}}"
                           RadiusX="2" RadiusY="2" Margin="-1,0,0,0"/>

                <Grid Grid.Column="1" Margin="14,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="{Binding Id}" FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimary}"/>
                        <TextBlock Text="{Binding TypeDisplay, Mode=OneWay}" FontSize="11"
                                   Foreground="{DynamicResource TextSecondary}"
                                   Margin="0,2,0,0"/>
                    </StackPanel>

                    <Button Grid.Column="1" Content="下载"
                            Style="{StaticResource PrimaryBtn}"
                            Height="28" FontSize="12" Padding="14,2"
                            Command="{Binding DataContext.DownloadCommand, ElementName=lstVersions}"
                            CommandParameter="{Binding Id}"/>
                </Grid>
            </Grid>
        </Border>

        <DataTemplate.Triggers>
            <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsSelected}" Value="True">
                <Setter TargetName="cardRoot" Property="Background" Value="{DynamicResource CardSelectedBg}"/>
                <Setter TargetName="cardRoot" Property="BorderBrush" Value="{DynamicResource AccentBlue}"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsMouseOver}" Value="True">
                <Setter TargetName="cardRoot" Property="Background" Value="{DynamicResource CardHoverBg}"/>
            </DataTrigger>
        </DataTemplate.Triggers>
    </DataTemplate>

    <!-- Schematic Card -->
    <DataTemplate x:Key="SchematicCardTemplate">
        <Border Margin="4,2" Padding="14,10" CornerRadius="6"
                Background="{DynamicResource CardBg}"
                BorderBrush="{DynamicResource PanelBorder}"
                BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="{Binding Name}" FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimary}"/>
                    <TextBlock Text="{Binding FullPath}" FontSize="11"
                               Foreground="{DynamicResource TextMuted}"
                               Margin="0,2,0,0"
                               TextTrimming="CharacterEllipsis"/>
                </StackPanel>

                <Button Grid.Column="1" Content="删除"
                        Style="{StaticResource DangerBtn}"
                        Height="26" FontSize="11" Padding="8,2"
                        Command="{Binding DataContext.DeleteSchematicCommand, ElementName=lstSchematics}"
                        CommandParameter="{Binding}"/>
            </Grid>
        </Border>
    </DataTemplate>

</ResourceDictionary>
