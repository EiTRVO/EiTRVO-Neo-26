    <!-- Resource Pack Download Card -->
    <DataTemplate x:Key="ResourcePackDownloadCardTemplate">
        <Border Margin="4,2" Padding="14,10" CornerRadius="6"
                Background="{DynamicResource CardBg}"
                BorderBrush="{DynamicResource PanelBorder}"
                BorderThickness="1"
                HorizontalAlignment="Stretch">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="44"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Column="0" Grid.RowSpan="2"
                        Width="36" Height="36" CornerRadius="6"
                        Background="{DynamicResource DeepDark}"
                        VerticalAlignment="Top" Margin="0,2,0,0">
                    <Image Source="{Binding IconUrl}" Width="36" Height="36"
                           Stretch="UniformToFill"/>
                </Border>

                <Grid Grid.Column="1" Grid.Row="0" Margin="10,0,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <TextBlock Text="{Binding Title}" FontSize="13"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimary}"
                                   TextTrimming="CharacterEllipsis"
                                   MaxWidth="260"/>
                        <TextBlock Text="{Binding DownloadsDisplay, StringFormat='  {0} ↓'}"
                                   FontSize="11"
                                   Foreground="{DynamicResource TextMuted}"
                                   VerticalAlignment="Center"
                                   Margin="6,0,0,0"/>
                    </StackPanel>
                    <Button Grid.Column="1" Content="下载"
                            Style="{StaticResource PrimaryBtn}"
                            Height="26" FontSize="12" Padding="12,1"
                            Visibility="{Binding IsDownloading, Converter={StaticResource BoolInvertConverter}}"
                            Command="{Binding DataContext.DownloadResourcePackCommand, ElementName=lstResourceSearchResults}"
                            CommandParameter="{Binding}"/>
                </Grid>

                <TextBlock Grid.Column="1" Grid.Row="1"
                           Text="{Binding Description}" FontSize="11"
                           Foreground="{DynamicResource TextSecondary}"
                           Margin="10,3,0,0"
                           TextTrimming="CharacterEllipsis"
                           ToolTip="{Binding Description}"/>

                <TextBlock Grid.Column="1" Grid.Row="2"
                           FontSize="10"
                           Foreground="{DynamicResource TextMuted}"
                           Margin="10,3,0,0">
                    <Run Text="by "/>
                    <Run Text="{Binding Author}"/>
                </TextBlock>

                <Border Grid.Column="0" Grid.ColumnSpan="2"
                        Grid.Row="3" Margin="0,8,0,0"
                        Padding="10,8" CornerRadius="5"
                        Background="{DynamicResource DeepDark}"
                        Visibility="{Binding IsDownloading, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid Grid.Row="0" Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="{Binding FileProgressDisplay}"
                                       FontSize="10"
                                       Foreground="{DynamicResource TextSecondary}"
                                       TextTrimming="CharacterEllipsis"/>
                            <TextBlock Grid.Column="0"
                                       Text="{Binding DownloadStatus}"
                                       FontSize="10"
                                       Foreground="{DynamicResource TextSecondary}"
                                       TextTrimming="CharacterEllipsis"
                                       Visibility="{Binding HasFileProgress, Converter={StaticResource BoolInvertConverter}}"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <TextBlock Text="{Binding DownloadProgress, StringFormat={}{0:F0}%}"
                                           FontSize="10"
                                           Foreground="{DynamicResource AccentBlue}"
                                           FontWeight="SemiBold"
                                           Margin="0,0,8,0"
                                           VerticalAlignment="Center"/>
                                <Button Content="取消"
                                        Style="{StaticResource DangerBtn}"
                                        Height="20" FontSize="10" Padding="6,0"
                                        Command="{Binding DataContext.CancelResourceDownloadCommand, ElementName=lstResourceSearchResults}"
                                        CommandParameter="{Binding}"/>
                            </StackPanel>
                        </Grid>
                        <ProgressBar Grid.Row="1"
                                     Height="4"
                                     Minimum="0" Maximum="100"
                                     Value="{Binding DownloadProgress}"
                                     IsIndeterminate="{Binding HasFileProgress, Converter={StaticResource BoolInvertConverter}}"
                                     Foreground="{DynamicResource AccentBlue}"
                                     Background="{DynamicResource DeepDark}"/>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </DataTemplate>

