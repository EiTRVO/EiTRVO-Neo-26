<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ============================ -->
    <!-- COLOR PALETTE                -->
    <!-- Catppuccin Mocha inspired   -->
    <!-- ============================ -->

    <!-- Backgrounds -->
    <SolidColorBrush x:Key="WindowBg" Color="#1E1E2E"/>
    <SolidColorBrush x:Key="PanelBg" Color="#24253A"/>
    <SolidColorBrush x:Key="CardBg" Color="#2A2B40"/>
    <SolidColorBrush x:Key="CardHoverBg" Color="#31335A"/>
    <SolidColorBrush x:Key="CardSelectedBg" Color="#3B3E6B"/>

    <!-- Borders -->
    <SolidColorBrush x:Key="PanelBorder" Color="#383A55"/>
    <SolidColorBrush x:Key="InputBorder" Color="#45475A"/>

    <!-- Text -->
    <SolidColorBrush x:Key="TextPrimary" Color="#CDD6F4"/>
    <SolidColorBrush x:Key="TextSecondary" Color="#878BA6"/>
    <SolidColorBrush x:Key="TextMuted" Color="#585B70"/>

    <!-- Accents -->
    <SolidColorBrush x:Key="AccentBlue" Color="#89B4FA"/>
    <SolidColorBrush x:Key="AccentRed" Color="#F38BA8"/>
    <SolidColorBrush x:Key="AccentOrange" Color="#FAB387"/>
    <SolidColorBrush x:Key="AccentGreen" Color="#A6E3A1"/>
    <SolidColorBrush x:Key="AccentYellow" Color="#F9E2AF"/>

    <!-- Controls -->
    <SolidColorBrush x:Key="Surface" Color="#313244"/>
    <SolidColorBrush x:Key="DeepDark" Color="#11111B"/>
    <SolidColorBrush x:Key="MutedText" Color="#6C7086"/>
    <SolidColorBrush x:Key="Subtext" Color="#A6ADC8"/>

    <!-- Buttons -->
    <SolidColorBrush x:Key="BtnBg" Color="#313244"/>
    <SolidColorBrush x:Key="BtnBorder" Color="#45475A"/>
    <SolidColorBrush x:Key="BtnHoverBg" Color="#45475A"/>
    <SolidColorBrush x:Key="PrimaryBtnBg" Color="#89B4FA"/>
    <SolidColorBrush x:Key="PrimaryBtnFg" Color="#1E1E2E"/>

    <!-- Status / Notifications -->
    <SolidColorBrush x:Key="InfoBrush" Color="#89B4FA"/>
    <SolidColorBrush x:Key="SuccessBrush" Color="#A6E3A1"/>
    <SolidColorBrush x:Key="WarningBrush" Color="#FAB387"/>
    <SolidColorBrush x:Key="ErrorBrush" Color="#F38BA8"/>

    <!-- Sidebar -->
    <SolidColorBrush x:Key="SidebarBg" Color="#1A1B26"/>
    <SolidColorBrush x:Key="SidebarBorder" Color="#2D2E40"/>
    <SolidColorBrush x:Key="MenuHoverBg" Color="#2A2B3D"/>
    <SolidColorBrush x:Key="MenuActiveBg" Color="#363752"/>

    <!-- Right Panel (Log) -->
    <SolidColorBrush x:Key="LogPanelBg" Color="#1A1B26"/>
    <SolidColorBrush x:Key="LogItemBg" Color="#24253A"/>
    <SolidColorBrush x:Key="LogItemBorder" Color="#2D2E40"/>

    <!-- ============================ -->
    <!-- IMPLICIT STYLES             -->
    <!-- ============================ -->

    <Style TargetType="TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
    </Style>

    <Style TargetType="TextBox">
        <Setter Property="Background" Value="{DynamicResource Surface}"/>
        <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource InputBorder}"/>
        <Setter Property="CaretBrush" Value="{DynamicResource TextPrimary}"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="1" CornerRadius="6" Padding="6,2">
                        <ScrollViewer x:Name="PART_ContentHost"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="PasswordBox">
        <Setter Property="Background" Value="{DynamicResource Surface}"/>
        <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource InputBorder}"/>
        <Setter Property="CaretBrush" Value="{DynamicResource TextPrimary}"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="PasswordBox">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="1" CornerRadius="6" Padding="6,2">
                        <ScrollViewer x:Name="PART_ContentHost"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="ComboBox">
        <Setter Property="Background" Value="{DynamicResource Surface}"/>
        <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource InputBorder}"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Padding" Value="8,0"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBox">
                    <Grid>
                        <ToggleButton x:Name="ToggleButton"
                                      IsChecked="{Binding Path=IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                      Background="{TemplateBinding Background}"
                                      BorderBrush="{TemplateBinding BorderBrush}"
                                      BorderThickness="{TemplateBinding BorderThickness}">
                            <ToggleButton.Template>
                                <ControlTemplate TargetType="ToggleButton">
                                    <Border Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            CornerRadius="6"/>
                                </ControlTemplate>
                            </ToggleButton.Template>
                        </ToggleButton>

                        <ContentPresenter x:Name="ContentSite"
                                          ContentSource="SelectionBoxItem"
                                          Margin="10,3,26,3"
                                          IsHitTestVisible="False"
                                          VerticalAlignment="Center"
                                          TextElement.Foreground="{TemplateBinding Foreground}"/>

                        <Path Data="M0,0 L4,4 L8,0"
                              Fill="{TemplateBinding Foreground}"
                              HorizontalAlignment="Right"
                              VerticalAlignment="Center"
                              Margin="0,0,8,0"
                              IsHitTestVisible="False"
                              Stretch="Uniform" Width="10" Height="6"/>

                        <Popup x:Name="Popup"
                               Placement="Bottom"
                               IsOpen="{TemplateBinding IsDropDownOpen}"
                               AllowsTransparency="True"
                               Focusable="False"
                               PopupAnimation="Slide"
                               Width="{Binding Path=ActualWidth, RelativeSource={RelativeSource TemplatedParent}}">
                            <Border x:Name="DropDownBorder"
                                    Background="{DynamicResource Surface}"
                                    BorderBrush="{DynamicResource InputBorder}"
                                    BorderThickness="1"
                                    CornerRadius="4"
                                    Margin="0,2,0,0"
                                    MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                <ScrollViewer>
                                    <ItemsPresenter/>
                                </ScrollViewer>
                            </Border>
                        </Popup>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Setter Property="ItemContainerStyle">
            <Setter.Value>
                <Style TargetType="ComboBoxItem">
                    <Setter Property="Background" Value="{DynamicResource Surface}"/>
                    <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
                </Style>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="ListBox">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
    </Style>

    <Style TargetType="ScrollViewer">
        <Setter Property="Background" Value="Transparent"/>
    </Style>

    <Style TargetType="ProgressBar">
        <Setter Property="Background" Value="{DynamicResource Surface}"/>
        <Setter Property="Foreground" Value="{DynamicResource AccentBlue}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource InputBorder}"/>
        <Setter Property="Height" Value="6"/>
    </Style>

    <Style TargetType="TabItem">
        <Setter Property="Background" Value="{DynamicResource Surface}"/>
        <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource InputBorder}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Padding" Value="14,6"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TabItem">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="1,1,1,0" CornerRadius="8,8,0,0"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter ContentSource="Header"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="GroupBox">
        <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource InputBorder}"/>
    </Style>

    <Style TargetType="ToolTip">
        <Setter Property="Background" Value="{DynamicResource Surface}"/>
        <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource PanelBorder}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="8,4"/>
        <Setter Property="FontSize" Value="12"/>
    </Style>

    <!-- ============================ -->
    <!-- NAMED STYLES                -->
    <!-- ============================ -->

    <!-- Standard Card Button -->
    <Style x:Key="CardBtn" TargetType="Button">
        <Setter Property="Height" Value="28"/>
        <Setter Property="MinWidth" Value="42"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Margin" Value="2,0"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bd" CornerRadius="6" Padding="8,3"
                            Background="Transparent"
                            BorderBrush="{DynamicResource BtnBorder}"
                            BorderThickness="1">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Background"
                                    Value="{DynamicResource BtnHoverBg}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Primary Action Button -->
    <Style x:Key="PrimaryBtn" TargetType="Button">
        <Setter Property="Height" Value="32"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Foreground" Value="{DynamicResource PrimaryBtnFg}"/>
        <Setter Property="Background" Value="{DynamicResource AccentBlue}"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                            CornerRadius="8" Padding="14,4">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Large Launch Button -->
    <Style x:Key="LaunchBtn" TargetType="Button">
        <Setter Property="Height" Value="48"/>
        <Setter Property="FontSize" Value="17"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Foreground" Value="{DynamicResource PrimaryBtnFg}"/>
        <Setter Property="Background" Value="{DynamicResource PrimaryBtnBg}"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                            CornerRadius="12" Padding="20,6">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Danger Button -->
    <Style x:Key="DangerBtn" TargetType="Button" BasedOn="{StaticResource CardBtn}">
        <Setter Property="Foreground" Value="{DynamicResource AccentRed}"/>
    </Style>

    <!-- Success Button -->
    <Style x:Key="SuccessBtn" TargetType="Button" BasedOn="{StaticResource CardBtn}">
        <Setter Property="Foreground" Value="{DynamicResource AccentGreen}"/>
    </Style>

    <!-- Filter Toggle Button -->
    <Style x:Key="FilterToggleBtn" TargetType="ToggleButton">
        <Setter Property="Height" Value="26"/>
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="{DynamicResource BtnBorder}"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Padding" Value="10,2"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToggleButton">
                    <Border x:Name="bd" CornerRadius="4"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="1"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          TextElement.Foreground="{TemplateBinding Foreground}"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="bd" Property="Background"
                                    Value="{DynamicResource AccentBlue}"/>
                            <Setter TargetName="bd" Property="BorderBrush"
                                    Value="{DynamicResource AccentBlue}"/>
                            <Setter Property="Foreground"
                                    Value="{DynamicResource PrimaryBtnFg}"/>
                        </Trigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsMouseOver" Value="True"/>
                                <Condition Property="IsChecked" Value="False"/>
                            </MultiTrigger.Conditions>
                            <Setter TargetName="bd" Property="Background"
                                    Value="{DynamicResource BtnHoverBg}"/>
                        </MultiTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- iOS-style Toggle Switch -->
    <Style x:Key="ToggleSwitchStyle" TargetType="CheckBox">
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="CheckBox">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Border x:Name="SwitchBorder" Width="44" Height="22"
                                CornerRadius="11"
                                Background="{DynamicResource InputBorder}"
                                BorderBrush="{DynamicResource BtnBorder}"
                                BorderThickness="1">
                            <Ellipse x:Name="Thumb" Width="16" Height="16"
                                     Fill="{DynamicResource TextPrimary}"
                                     HorizontalAlignment="Left"
                                     VerticalAlignment="Center"
                                     Margin="2,0,0,0"/>
                        </Border>
                        <ContentPresenter Grid.Column="1" Margin="10,0,0,0"
                                          VerticalAlignment="Center"
                                          RecognizesAccessKey="True"/>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="SwitchBorder" Property="Background"
                                    Value="{DynamicResource AccentBlue}"/>
                            <Setter TargetName="SwitchBorder" Property="BorderBrush"
                                    Value="{DynamicResource AccentBlue}"/>
                            <Setter TargetName="Thumb" Property="Fill"
                                    Value="{DynamicResource PrimaryBtnFg}"/>
                            <Setter TargetName="Thumb" Property="HorizontalAlignment"
                                    Value="Right"/>
                            <Setter TargetName="Thumb" Property="Margin"
                                    Value="0,0,2,0"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============================ -->
    <!-- DATA TEMPLATES              -->
    <!-- ============================ -->

    <!-- Java Runtime List Item -->
    <DataTemplate x:Key="JavaItemTemplate">
        <StackPanel Orientation="Horizontal" Margin="4,3">
            <TextBlock Text="{Binding ShortVersion}" FontWeight="SemiBold"
                       Margin="0,0,10,0"
                       Foreground="{DynamicResource TextPrimary}"/>
            <TextBlock Text="{Binding Path}"
                       Foreground="{DynamicResource TextSecondary}"
                       TextTrimming="CharacterEllipsis" MaxWidth="420"/>
        </StackPanel>
    </DataTemplate>

    <!-- Sidebar Nav Item Style (legacy Border, kept for reference) -->
    <Style x:Key="SidebarNavItem" TargetType="Border">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Padding" Value="14,8"/>
        <Setter Property="Margin" Value="6,1"/>
        <Setter Property="CornerRadius" Value="6"/>
    </Style>

    <!-- Sidebar Nav Button (keyboard-accessible replacement) -->
    <Style x:Key="SidebarNavButton" TargetType="Button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Padding" Value="14,8"/>
        <Setter Property="Margin" Value="6,1"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="HorizontalContentAlignment" Value="Left"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                            CornerRadius="6"
                            Padding="{TemplateBinding Padding}"
                            Margin="{TemplateBinding Margin}">
                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="{DynamicResource MenuHoverBg}"/>
                        </Trigger>
                        <Trigger Property="IsFocused" Value="True">
                            <Setter Property="Background" Value="{DynamicResource MenuHoverBg}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- GridSplitter implicit -->
    <Style TargetType="GridSplitter">
        <Setter Property="Background" Value="{DynamicResource SidebarBorder}"/>
        <Setter Property="Width" Value="2"/>
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
    </Style>

    <!-- Log Entry DataTemplate -->
    <DataTemplate x:Key="LogEntryTemplate">
        <Border Padding="8,4" Margin="2,1"
                Background="{DynamicResource LogItemBg}"
                CornerRadius="4"
                BorderBrush="{DynamicResource LogItemBorder}"
                BorderThickness="0,0,0,1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <StackPanel Grid.Row="0" Orientation="Horizontal">
                    <TextBlock Text="{Binding TimeDisplay, Mode=OneWay}" FontSize="10"
                               Foreground="{DynamicResource TextMuted}"
                               Margin="0,0,8,0"/>
                    <Ellipse Width="8" Height="8"
                             Fill="{Binding Type, Converter={StaticResource NotificationTypeToBrushConverter}}"
                             Margin="0,0,6,0" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding TypeLabel, Mode=OneWay}" FontSize="10"
                               Foreground="{Binding Type, Converter={StaticResource NotificationTypeToBrushConverter}}"
                               FontWeight="SemiBold" Margin="0,0,6,0"/>
                </StackPanel>
                <TextBlock Grid.Row="1" Text="{Binding Message}"
                           FontSize="12" TextWrapping="Wrap"
                           Foreground="{DynamicResource TextPrimary}"
                           Margin="0,2,0,0"/>
            </Grid>
        </Border>
    </DataTemplate>

</ResourceDictionary>
