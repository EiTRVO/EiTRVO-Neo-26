<Application x:Class="EiTRVO.UI.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
>
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Themes/Converters.xaml"/>
                <ResourceDictionary Source="Themes/DarkTheme.xaml"/>
                <ResourceDictionary Source="Themes/DataTemplates.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <FontFamily x:Key="CustomFont">/font/Font.ttf#HarmonyOS Sans SC</FontFamily>
        </ResourceDictionary>
    </Application.Resources>
</Application>
